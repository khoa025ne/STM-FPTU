@page
@model FPT_SM.Web.Pages.Manager.DashboardModel
@{
    Layout = "_ManagerLayout";
    ViewData["Title"] = "Dashboard - Quản lý";
    var data = Model.DashboardData;
}

<!-- Stats Cards -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-8">
    <!-- Lớp chờ duyệt -->
    <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 hover:shadow-md transition-shadow" data-aos="fade-up" data-aos-delay="0">
        <div class="flex items-center justify-between mb-3">
            <div class="w-11 h-11 bg-amber-100 rounded-xl flex items-center justify-center">
                <i data-lucide="clock" class="w-5 h-5 text-amber-500"></i>
            </div>
            <span class="text-xs font-semibold text-amber-600 bg-amber-50 px-2 py-1 rounded-full">Chờ duyệt</span>
        </div>
        <p class="text-slate-500 text-sm font-medium">Lớp chờ duyệt</p>
        <p class="text-3xl font-black text-amber-500 mt-1">@(data?.PendingClasses ?? 0)</p>
        <p class="text-xs text-slate-400 mt-1">Cần xem xét và phê duyệt</p>
    </div>

    <!-- Lớp đang diễn ra -->
    <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 hover:shadow-md transition-shadow" data-aos="fade-up" data-aos-delay="80">
        <div class="flex items-center justify-between mb-3">
            <div class="w-11 h-11 bg-teal-100 rounded-xl flex items-center justify-center">
                <i data-lucide="graduation-cap" class="w-5 h-5 text-teal-500"></i>
            </div>
            <span class="text-xs font-semibold text-teal-600 bg-teal-50 px-2 py-1 rounded-full">Đang học</span>
        </div>
        <p class="text-slate-500 text-sm font-medium">Lớp đang diễn ra</p>
        <p class="text-3xl font-black text-teal-600 mt-1">@(data?.TotalClasses ?? 0)</p>
        <p class="text-xs text-slate-400 mt-1">@(data?.TotalEnrollments ?? 0) lượt đăng ký</p>
    </div>

    <!-- Tổng sinh viên -->
    <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 hover:shadow-md transition-shadow" data-aos="fade-up" data-aos-delay="160">
        <div class="flex items-center justify-between mb-3">
            <div class="w-11 h-11 bg-fpt-navy/10 rounded-xl flex items-center justify-center">
                <i data-lucide="users" class="w-5 h-5 text-fpt-navy"></i>
            </div>
            <span class="text-xs font-semibold text-fpt-navy bg-blue-50 px-2 py-1 rounded-full">Sinh viên</span>
        </div>
        <p class="text-slate-500 text-sm font-medium">Tổng sinh viên</p>
        <p class="text-3xl font-black text-fpt-navy mt-1">@(data?.TotalStudents.ToString("N0") ?? "—")</p>
        <p class="text-xs text-slate-400 mt-1">Tỉ lệ đậu: <span class="text-teal-600 font-semibold">@(data?.PassRate.ToString("F1") ?? "0")%</span></p>
    </div>
</div>

<!-- Main Content Row -->
<div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
    <!-- Pending Approval Table -->
    <div class="xl:col-span-2 bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden" data-aos="fade-up" data-aos-delay="100">
        <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
            <div>
                <h3 class="font-bold text-slate-800">Danh sách lớp chờ phê duyệt</h3>
                <p class="text-slate-400 text-xs mt-0.5">Các lớp đang chờ được xem xét</p>
            </div>
            <a href="/Manager/Classes" class="text-xs text-fpt-orange hover:underline font-medium">Xem tất cả</a>
        </div>

        @if (data?.ClassesPendingApproval?.Any() == true)
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-slate-50 text-left">
                            <th class="px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Lớp học</th>
                            <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Môn học</th>
                            <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Giáo viên</th>
                            <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Sĩ số</th>
                            <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        @foreach (var cls in data.ClassesPendingApproval.Take(8))
                        {
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="px-6 py-3.5">
                                    <p class="font-semibold text-slate-700">@cls.Name</p>
                                    <p class="text-xs text-slate-400">@cls.DayName · @cls.StartTime.ToString(@"hh\:mm") - @cls.EndTime.ToString(@"hh\:mm")</p>
                                </td>
                                <td class="px-4 py-3.5">
                                    <p class="font-medium text-slate-600">@cls.SubjectCode</p>
                                    <p class="text-xs text-slate-400 truncate max-w-[120px]">@cls.SubjectName</p>
                                </td>
                                <td class="px-4 py-3.5 text-slate-600 text-sm">@cls.TeacherName</td>
                                <td class="px-4 py-3.5">
                                    <span class="text-sm font-medium text-slate-700">@cls.Enrolled/@cls.Capacity</span>
                                </td>
                                <td class="px-4 py-3.5">
                                    <div class="flex items-center gap-2">
                                        <button onclick="approveClass(@cls.Id)"
                                                class="flex items-center gap-1 bg-teal-500 hover:bg-teal-600 text-white text-xs font-semibold px-3 py-1.5 rounded-lg transition-colors">
                                            <i data-lucide="check" class="w-3 h-3"></i>
                                            Duyệt
                                        </button>
                                        <button onclick="rejectClass(@cls.Id)"
                                                class="flex items-center gap-1 bg-red-50 hover:bg-red-100 text-red-600 text-xs font-semibold px-3 py-1.5 rounded-lg transition-colors">
                                            <i data-lucide="x" class="w-3 h-3"></i>
                                            Hủy
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="flex flex-col items-center justify-center py-16 text-center">
                <div class="w-14 h-14 bg-teal-50 rounded-full flex items-center justify-center mb-3">
                    <i data-lucide="check-circle-2" class="w-7 h-7 text-teal-400"></i>
                </div>
                <p class="text-slate-500 font-medium">Không có lớp nào chờ duyệt</p>
                <p class="text-slate-400 text-xs mt-1">Tất cả lớp học đã được xử lý</p>
            </div>
        }
    </div>

    <!-- Class Status Bar Chart -->
    <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100" data-aos="fade-up" data-aos-delay="200">
        <div class="flex items-center justify-between mb-5">
            <div>
                <h3 class="text-base font-bold text-slate-800">Lớp theo trạng thái</h3>
                <p class="text-slate-400 text-xs mt-0.5">Phân bố hiện tại</p>
            </div>
            <div class="w-9 h-9 bg-fpt-orange/10 rounded-xl flex items-center justify-center">
                <i data-lucide="bar-chart-2" class="w-4 h-4 text-fpt-orange"></i>
            </div>
        </div>
        <div style="height:260px;">
            <canvas id="classStatusChart"></canvas>
        </div>

        <!-- Active Semesters -->
        @if (data?.ActiveSemesters?.Any() == true)
        {
            <div class="mt-4 pt-4 border-t border-slate-100 space-y-2">
                <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Học kỳ đang mở</p>
                @foreach (var sem in data.ActiveSemesters.Take(3))
                {
                    <div class="flex items-center justify-between">
                        <span class="text-sm text-slate-600 truncate">@sem.Name</span>
                        <span class="text-xs bg-teal-100 text-teal-700 px-2 py-0.5 rounded-full font-medium ml-2 flex-shrink-0">@sem.ClassCount lớp</span>
                    </div>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    function approveClass(id) {
        Swal.fire({
            title: 'Xác nhận duyệt lớp?',
            text: 'Lớp học sẽ được kích hoạt và hiển thị cho sinh viên.',
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#14B8A6',
            cancelButtonColor: '#94a3b8',
            confirmButtonText: 'Duyệt ngay',
            cancelButtonText: 'Hủy'
        }).then(result => {
            if (result.isConfirmed) {
                window.location.href = `/Manager/Classes?handler=Approve&id=${id}`;
            }
        });
    }

    function rejectClass(id) {
        Swal.fire({
            title: 'Hủy lớp học này?',
            text: 'Hành động này không thể hoàn tác.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#EF4444',
            cancelButtonColor: '#94a3b8',
            confirmButtonText: 'Xác nhận hủy',
            cancelButtonText: 'Không'
        }).then(result => {
            if (result.isConfirmed) {
                window.location.href = `/Manager/Classes?handler=Reject&id=${id}`;
            }
        });
    }

    // Class Status Bar Chart
    (function () {
        const ctx = document.getElementById('classStatusChart')?.getContext('2d');
        if (!ctx) return;
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['Chờ duyệt', 'Đang mở', 'Đang học', 'Kết thúc'],
                datasets: [{
                    label: 'Số lớp',
                    data: [
                        @(data?.PendingClasses ?? 0),
                        @(data?.TotalClasses ?? 0),
                        Math.round(@(data?.TotalClasses ?? 0) * 0.6),
                        Math.round(@(data?.TotalClasses ?? 0) * 0.3)
                    ],
                    backgroundColor: ['#FCD34D', '#0EA5E9', '#14B8A6', '#94a3b8'],
                    borderRadius: 8,
                    borderSkipped: false
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: { label: ctx => ctx.parsed.y + ' lớp' }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(0,0,0,0.04)' },
                        ticks: { font: { size: 11 }, stepSize: 1 }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { font: { size: 11 } }
                    }
                }
            }
        });
    })();

    // SignalR - Listen for real-time Admin updates
    (async function () {
        try {
            const conn = await signalRManager.connect('notification', '/hubs/notification');
            await conn.invoke('JoinGroup', 'manager_all');

            // Listen for user updates from Admin
            conn.on('UserUpdated', async function (data) {
                showToast('Cập nhật người dùng', `Người dùng: ${data.action}`, 'info');
                await new Promise(r => setTimeout(r, 1000));
                window.location.reload();
            });

            // Listen for semester updates from Admin
            conn.on('SemesterUpdated', async function (data) {
                showToast('Cập nhật học kỳ', `Hành động: ${data.action}`, 'info');
                await new Promise(r => setTimeout(r, 1000));
                window.location.reload();
            });

            // Listen for class updates from Admin
            conn.on('ClassUpdated', async function (data) {
                const actions = {
                    create: 'Lớp mới chờ duyệt',
                    edit: 'Lớp đã sửa',
                    delete: 'Lớp đã xóa'
                };
                showToast('Quản lý lớp', actions[data.action] || data.action, 'info');
                await new Promise(r => setTimeout(r, 1000));
                window.location.reload();
            });

            // Listen for enrollment changes from Students
            conn.on('EnrollmentChanged', async function (data) {
                showToast(
                    'Thay đổi đăng ký',
                    `${data.className}: ${data.enrolled}/${data.capacity} sinh viên`,
                    'info'
                );
            });

        } catch (e) { console.warn('SignalR not connected', e); }
    })();
</script>
}
