@page
@model FPT_SM.Web.Pages.Admin.Reports.IndexModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using System.Text.Json
@using System.Globalization
@{
    Layout = "_AdminLayout";
    var chartLabels = Model.RevenueReport.Monthly.Select(m => m.Month).ToList();
    var revenueValues = Model.RevenueReport.Monthly.Select(m => m.Revenue).ToList();
    var passLabels = Model.GradeReports.Select(g => g.SubjectCode).ToList();
    var passValues = Model.GradeReports.Select(g => Math.Round(g.PassRate, 1)).ToList();
    var failValues = Model.GradeReports.Select(g => g.FailCount).ToList();
    var semesterLabels = Model.SemesterTrends.Select(s => s.SemesterName).ToList();
    var semesterValues = Model.SemesterTrends.Select(s => s.EnrollmentCount).ToList();
}

<style>
    .usage-report .panel {
        background: #fff;
        border: 1px solid #d4d4d8;
        border-radius: 18px;
        box-shadow: none;
    }

    .usage-report .panel-title {
        color: #111827;
        font-weight: 800;
        letter-spacing: -0.01em;
    }

    .usage-report .chip {
        background: #f4f4f5;
        color: #18181b;
        border: 1px solid #e4e4e7;
    }
</style>

<div class="usage-report space-y-6">
    <div class="panel p-4 flex flex-col md:flex-row gap-6 items-center">
        <div class="flex-1">
            <p class="text-zinc-500 text-xs uppercase tracking-wider">Usage Analytics</p>
            <h1 class="text-2xl panel-title">Báo cáo FPTSM</h1>
            <p class="text-xs text-slate-500 mt-1">Tháng @Model.Month/@Model.Year</p>
        </div>
        <div class="flex flex-wrap gap-3">
            <a href="/Admin/Users" class="chip px-4 py-2 rounded-lg text-sm font-semibold hover:bg-zinc-200 transition">
                SV: @Model.Overview.TotalStudents
            </a>
            <a href="/Admin/Users" class="chip px-4 py-2 rounded-lg text-sm font-semibold hover:bg-zinc-200 transition">
                GV: @Model.Overview.TotalTeachers
            </a>
            <a href="/Admin/Dashboard" class="px-4 py-2 rounded-lg bg-zinc-900 text-white text-sm font-semibold hover:bg-black transition">
                Doanh thu: @Model.Overview.TotalRevenue.ToString("N0") VNĐ
            </a>
        </div>
    </div>

    @if (Model.EnableComparison && (Model.RevenueChangePercent != 0 || Model.EnrollmentChangePercent != 0))
    {
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="panel p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs text-slate-400 font-semibold">Thay đổi doanh thu</p>
                        <h3 class="text-2xl font-bold text-slate-800 mt-2">@Model.RevenueChangePercent.ToString("+0.0;-0.0;0")%</h3>
                        <p class="text-xs text-slate-500 mt-1">So với tháng @Model.ComparisonMonth/@Model.ComparisonYear</p>
                    </div>
                    <div class="text-4xl text-zinc-700">
                        @if (Model.RevenueChangePercent >= 0)
                        {
                            <span>📈</span>
                        }
                        else
                        {
                            <span>📉</span>
                        }
                    </div>
                </div>
            </div>
            <div class="panel p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs text-slate-400 font-semibold">Thay đổi đăng ký</p>
                        <h3 class="text-2xl font-bold text-slate-800 mt-2">@Model.EnrollmentChangePercent.ToString("+0.0;-0.0;0")%</h3>
                        <p class="text-xs text-slate-500 mt-1">Số lượng sinh viên đăng ký</p>
                    </div>
                    <div class="text-4xl text-zinc-700">
                        @if (Model.EnrollmentChangePercent >= 0)
                        {
                            <span>📈</span>
                        }
                        else
                        {
                            <span>📉</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-[2fr_1fr] gap-6">
        <div class="panel p-6 space-y-6">
            <div class="flex flex-wrap gap-4 items-center justify-between">
                <div>
                    <h2 class="text-lg panel-title">Lọc dữ liệu</h2>
                    <p class="text-xs text-slate-400">Chọn kỳ/ tháng để cập nhật số liệu.</p>
                </div>
            </div>
            <form method="get" class="grid grid-cols-1 sm:grid-cols-5 gap-3" id="filterForm">
                <!-- Primary filters -->
                <div id="primaryMonthField" style="display: @(Model.ComparisonMode == "month" ? "block" : "none");">
                    <label class="text-xs font-semibold text-slate-500">
                        Tháng
                        <select asp-for="Month" class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                            @for (int m = 1; m <= 12; m++)
                            {
                                <option value="@m">@CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(m)</option>
                            }
                        </select>
                    </label>
                </div>
                <label class="text-xs font-semibold text-slate-500">
                    Năm
                    <select asp-for="Year" class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                        @for (int y = 2024; y <= DateTime.Now.Year; y++)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </label>

                <!-- Comparison mode toggle -->
                <div class="text-xs font-semibold text-slate-500">
                    <label class="block mb-2">Kiểu so sánh</label>
                    <div class="flex gap-2">
                        <label class="flex items-center gap-1 cursor-pointer">
                            <input type="radio" name="ComparisonMode" value="month" @(Model.ComparisonMode == "month" ? "checked" : "") class="w-3 h-3 comparison-mode-radio" />
                            <span class="text-xs">Tháng</span>
                        </label>
                        <label class="flex items-center gap-1 cursor-pointer">
                            <input type="radio" name="ComparisonMode" value="year" @(Model.ComparisonMode == "year" ? "checked" : "") class="w-3 h-3 comparison-mode-radio" />
                            <span class="text-xs">Năm</span>
                        </label>
                    </div>
                </div>

                <!-- Month-based comparison -->
                <div id="monthComparisonFields" style="display: @(Model.ComparisonMode == "month" ? "block" : "none");">
                    <label class="text-xs font-semibold text-slate-500">
                        Tháng so sánh
                        <select asp-for="ComparisonMonth" class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                            @for (int m = 1; m <= 12; m++)
                            {
                                <option value="@m">@CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(m)</option>
                            }
                        </select>
                    </label>
                </div>

                <!-- Year-comparison month field -->
                <div id="yearComparisonMonthFields" style="display: @(Model.ComparisonMode == "year" ? "none" : "block");">
                    <label class="text-xs font-semibold text-slate-500">
                        Năm so sánh
                        <select asp-for="ComparisonYear" class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                            @for (int y = 2024; y <= DateTime.Now.Year; y++)
                            {
                                <option value="@y">@y</option>
                            }
                        </select>
                    </label>
                </div>

                <!-- Year-based comparison -->
                <div id="yearComparisonFields" style="display: @(Model.ComparisonMode == "year" ? "block" : "none");">
                    <label class="text-xs font-semibold text-slate-500">
                        So sánh với năm
                        <select asp-for="ComparisonYearForYearComparison" class="mt-1 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                            @for (int y = 2024; y < DateTime.Now.Year; y++)
                            {
                                <option value="@y">@y</option>
                            }
                        </select>
                    </label>
                </div>

                <!-- Comparison checkbox -->
                <div class="flex items-end">
                    <label class="text-xs font-semibold text-slate-500 flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" asp-for="EnableComparison" class="w-4 h-4 rounded border-slate-300 cursor-pointer" />
                        <span>Bật so sánh</span>
                    </label>
                </div>

                <!-- Submit button -->
                <div class="sm:col-span-5 flex gap-3">
                    <button class="flex-1 py-2 rounded-xl bg-zinc-900 text-white text-sm font-bold hover:bg-black transition" type="submit">
                        Áp dụng
                    </button>
                </div>
            </form>
        </div>
        <div class="panel p-6 space-y-4">
            <h3 class="text-sm font-semibold text-slate-500">Xuất báo cáo</h3>
            <form method="post" asp-page-handler="ExportExcel" class="space-y-3">
                <input type="hidden" asp-for="Month" />
                <input type="hidden" asp-for="Year" />
                <button type="submit" class="w-full py-2 rounded-xl bg-zinc-800 text-white text-sm font-bold hover:bg-black">Tải Excel</button>
            </form>
            <form method="post" asp-page-handler="ExportPdf" class="space-y-3">
                <input type="hidden" asp-for="Month" />
                <input type="hidden" asp-for="Year" />
                <button type="submit" class="w-full py-2 rounded-xl bg-slate-800 text-white text-sm font-bold hover:bg-slate-900">Tải PDF</button>
            </form>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="panel p-4">
            <p class="text-xs text-slate-400">Doanh thu theo tháng</p>
            <canvas id="revenueChart" height="180"></canvas>
        </div>
        <div class="panel p-4">
            <p class="text-xs text-slate-400">Tỉ lệ đậu/rớt theo môn</p>
            <canvas id="gradeChart" height="180"></canvas>
        </div>
        <div class="panel p-4">
            <p class="text-xs text-slate-400">Đăng ký theo học kỳ</p>
            <canvas id="semesterChart" height="180"></canvas>
        </div>
    </div>

    @if (Model.EnableComparison && Model.RevenueComparison?.Monthly?.Count > 0)
    {
        <div class="panel p-6 space-y-4">
            <h3 class="text-lg panel-title">So sánh doanh thu</h3>
            <p class="text-xs text-slate-500">@Model.CurrentPeriodName vs @Model.ComparisonPeriodName</p>
            <canvas id="comparisonChart" height="80"></canvas>
        </div>
    }

    <div class="panel p-6 space-y-4">
        <div class="flex items-center justify-between">
            <h3 class="text-lg panel-title">Top môn học được đăng ký</h3>
            <span class="text-xs text-slate-500">Hiển thị 5 môn nhiều SV nhất</span>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left text-slate-600">
                <thead>
                    <tr class="text-xs uppercase tracking-wide text-slate-400">
                        <th class="py-3 pr-4">Môn học</th>
                        <th class="py-3 pr-4">Lớp</th>
                        <th class="py-3 pr-4">Đăng ký</th>
                        <th class="py-3 pr-4">Sức chứa</th>
                        <th class="py-3 pr-4">Tỉ lệ lấp đầy</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var item in Model.TopSubjects)
                    {
                        <tr>
                            <td class="py-3 pr-4">@item.SubjectName (@item.SubjectCode)</td>
                            <td class="py-3 pr-4">@item.ClassName</td>
                            <td class="py-3 pr-4">@item.TotalEnrolled</td>
                            <td class="py-3 pr-4">@item.Capacity</td>
                            <td class="py-3 pr-4">
                                <div class="h-2.5 bg-slate-200 rounded-full">
                                    <div class="h-2.5 bg-zinc-800 rounded-full" style="width:@(item.Capacity > 0 ? (item.TotalEnrolled * 100 / item.Capacity) : 0)%"></div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let revenueChartInstance;
    let gradeChartInstance;
    let semesterChartInstance;
    let comparisonChartInstance;

    function getThemeTokens() {
        const mystic = document.documentElement.classList.contains('theme-mystic');
        return mystic
            ? {
                linePrimary: '#38bdf8',
                fillPrimary: 'rgba(56,189,248,0.16)',
                lineSecondary: '#a78bfa',
                fillSecondary: 'rgba(167,139,250,0.14)',
                neutral: '#94a3b8',
                grid: 'rgba(148,163,184,0.24)',
                ticks: '#cbd5e1'
            }
            : {
                linePrimary: '#0f172a',
                fillPrimary: 'rgba(15,23,42,0.10)',
                lineSecondary: '#fb7185',
                fillSecondary: 'rgba(251,113,133,0.14)',
                neutral: '#64748b',
                grid: 'rgba(100,116,139,0.22)',
                ticks: '#475569'
            };
    }

    function axisOptions(tokens, formatter) {
        return {
            beginAtZero: true,
            grid: { color: tokens.grid },
            ticks: {
                color: tokens.ticks,
                callback: formatter
            }
        };
    }

    function renderReportCharts() {
        const tokens = getThemeTokens();

        if (revenueChartInstance) revenueChartInstance.destroy();
        if (gradeChartInstance) gradeChartInstance.destroy();
        if (semesterChartInstance) semesterChartInstance.destroy();
        if (comparisonChartInstance) comparisonChartInstance.destroy();

        const revenueCtx = document.getElementById('revenueChart');
        revenueChartInstance = new Chart(revenueCtx, {
            type: 'line',
            data: {
                labels: @Html.Raw(JsonSerializer.Serialize(chartLabels)),
                datasets: [{
                    label: 'Doanh thu',
                    borderColor: tokens.linePrimary,
                    backgroundColor: tokens.fillPrimary,
                    data: @Html.Raw(JsonSerializer.Serialize(revenueValues)),
                    tension: 0.38,
                    fill: true,
                    borderWidth: 2.4,
                    pointRadius: 3,
                    pointHoverRadius: 6
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { labels: { color: tokens.ticks } } },
                scales: {
                    y: axisOptions(tokens, value => value.toLocaleString('vi-VN')),
                    x: { grid: { color: tokens.grid }, ticks: { color: tokens.ticks } }
                }
            }
        });

        const gradeCtx = document.getElementById('gradeChart');
        gradeChartInstance = new Chart(gradeCtx, {
            type: 'line',
            data: {
                labels: @Html.Raw(JsonSerializer.Serialize(passLabels)),
                datasets: [
                    {
                        label: 'Đậu (%)',
                        borderColor: tokens.linePrimary,
                        backgroundColor: tokens.fillPrimary,
                        data: @Html.Raw(JsonSerializer.Serialize(passValues)),
                        tension: 0.35,
                        fill: true,
                        borderWidth: 2.2,
                        pointRadius: 2.8
                    },
                    {
                        label: 'Rớt (SV)',
                        borderColor: tokens.lineSecondary,
                        backgroundColor: tokens.fillSecondary,
                        data: @Html.Raw(JsonSerializer.Serialize(failValues)),
                        tension: 0.35,
                        fill: true,
                        borderWidth: 2.2,
                        pointRadius: 2.8
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: { legend: { labels: { color: tokens.ticks } } },
                scales: {
                    y: axisOptions(tokens, value => value),
                    x: { grid: { color: tokens.grid }, ticks: { color: tokens.ticks } }
                }
            }
        });

        const semesterCtx = document.getElementById('semesterChart');
        semesterChartInstance = new Chart(semesterCtx, {
            type: 'line',
            data: {
                labels: @Html.Raw(JsonSerializer.Serialize(semesterLabels)),
                datasets: [{
                    label: 'Sinh viên',
                    borderColor: tokens.neutral,
                    backgroundColor: 'rgba(148,163,184,0.15)',
                    data: @Html.Raw(JsonSerializer.Serialize(semesterValues)),
                    tension: 0.28,
                    fill: true,
                    borderWidth: 2,
                    pointRadius: 2.5
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { labels: { color: tokens.ticks } } },
                scales: {
                    y: axisOptions(tokens, value => value),
                    x: { grid: { color: tokens.grid }, ticks: { color: tokens.ticks } }
                }
            }
        });
    }

    // Comparison chart
    @if (Model.EnableComparison && Model.RevenueComparison?.Monthly?.Count > 0)
    {
        var comparisonLabels = new List<string> { Model.CurrentPeriodName, Model.ComparisonPeriodName };
        var currentTotal = Model.RevenueReport.Monthly.Sum(m => m.Revenue);
        var previousTotal = Model.RevenueComparison.Monthly.Sum(m => m.Revenue);
        <text>
        function renderComparisonChart() {
            const tokens = getThemeTokens();
            const comparisonCtx = document.getElementById('comparisonChart');
            comparisonChartInstance = new Chart(comparisonCtx, {
                type: 'line',
                data: {
                    labels: @Html.Raw(JsonSerializer.Serialize(comparisonLabels)),
                    datasets: [{
                        label: 'Doanh thu (VNĐ)',
                        borderColor: tokens.linePrimary,
                        backgroundColor: tokens.fillPrimary,
                        data: [@currentTotal, @previousTotal],
                        tension: 0.15,
                        fill: true,
                        borderWidth: 2.4,
                        pointRadius: 4,
                        pointHoverRadius: 7
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { labels: { color: tokens.ticks } } },
                    scales: {
                        y: axisOptions(tokens, value => value.toLocaleString('vi-VN')),
                        x: { grid: { color: tokens.grid }, ticks: { color: tokens.ticks } }
                    }
                }
            });
        }
        </text>
    }

    renderReportCharts();
    @if (Model.EnableComparison && Model.RevenueComparison?.Monthly?.Count > 0)
    {
        <text>renderComparisonChart();</text>
    }

    // Handle comparison mode radio button changes
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.comparison-mode-radio').forEach(radio => {
            radio.addEventListener('change', function() {
                const mode = this.value;
                const primaryMonthField = document.getElementById('primaryMonthField');
                const monthFields = document.getElementById('monthComparisonFields');
                const yearMonthFields = document.getElementById('yearComparisonMonthFields');
                const yearFields = document.getElementById('yearComparisonFields');
                
                if (mode === 'month') {
                    primaryMonthField.style.display = 'block';
                    monthFields.style.display = 'block';
                    yearMonthFields.style.display = 'block';
                    yearFields.style.display = 'none';
                } else {
                    primaryMonthField.style.display = 'none';
                    monthFields.style.display = 'none';
                    yearMonthFields.style.display = 'none';
                    yearFields.style.display = 'block';
                }
            });
        });

        window.addEventListener('admin-theme-changed', () => {
            renderReportCharts();
            @if (Model.EnableComparison && Model.RevenueComparison?.Monthly?.Count > 0)
            {
                <text>renderComparisonChart();</text>
            }
        });
    });
</script>
}
