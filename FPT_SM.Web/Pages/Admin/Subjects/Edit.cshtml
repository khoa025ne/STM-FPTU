@page
@model FPT_SM.Web.Pages.Admin.Subjects.EditModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = $"Sửa: {Model.Subject?.Name ?? "Môn học"}";
}

<!-- Breadcrumb -->
<nav class="flex items-center gap-2 text-sm text-slate-400 mb-6" data-aos="fade-down">
    <a href="/Admin/Subjects" class="hover:text-fpt-navy transition-colors">Quản lý Môn học</a>
    <i data-lucide="chevron-right" class="w-4 h-4"></i>
    <span class="text-slate-600 font-medium">Sửa thông tin</span>
</nav>

@if (Model.Subject == null)
{
    <div class="text-center py-20 text-slate-400">
        <i data-lucide="book-x" class="w-12 h-12 mx-auto mb-3 opacity-30"></i>
        <p class="font-medium">Không tìm thấy môn học</p>
        <a href="/Admin/Subjects" class="text-fpt-orange text-sm mt-2 inline-block hover:underline">Quay lại danh sách</a>
    </div>
}
else
{
    var statusBadge = Model.Subject.IsActive ? "bg-teal-100 text-teal-700" : "bg-slate-100 text-slate-600";
    var statusLabel = Model.Subject.IsActive ? "Hoạt động" : "Ngừng hoạt động";

    <div class="max-w-2xl mx-auto space-y-5" data-aos="fade-up">

        <!-- Subject Info Card -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-5 flex items-center gap-4">
            <div class="w-16 h-16 rounded-full bg-gradient-to-br from-fpt-navy to-blue-700 flex items-center justify-center text-white text-2xl font-black flex-shrink-0 ring-2 ring-fpt-orange/30">
                <i data-lucide="book-open" class="w-8 h-8"></i>
            </div>
            <div class="flex-1 min-w-0">
                <h3 class="font-bold text-slate-800 text-lg">@Model.Subject.Name</h3>
                <p class="text-slate-400 text-sm">Mã: @Model.Subject.Code</p>
                <div class="flex items-center gap-2 mt-1.5">
                    <span class="text-xs font-semibold px-2.5 py-0.5 rounded-full @statusBadge">@statusLabel</span>
                </div>
            </div>
        </div>

        <!-- Main Form -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
            <div class="bg-gradient-to-r from-fpt-navy to-blue-800 px-6 py-4">
                <div class="flex items-center gap-3">
                    <i data-lucide="edit-3" class="w-5 h-5 text-white"></i>
                    <h2 class="text-white font-bold">Cập nhật thông tin</h2>
                </div>
            </div>

            <form method="post" class="p-6 space-y-5">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <!-- Validation Summary -->
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="bg-red-50 border border-red-200 rounded-xl p-4 flex items-start gap-3">
                        <i data-lucide="alert-circle" class="w-5 h-5 text-red-500 flex-shrink-0 mt-0.5"></i>
                        <div>
                            <p class="text-sm font-semibold text-red-700 mb-1">Vui lòng kiểm tra lại:</p>
                            <ul class="text-sm text-red-600 space-y-0.5">
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <li>• @error.ErrorMessage</li>
                                }
                            </ul>
                        </div>
                    </div>
                }

                <!-- Mã môn học -->
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                        Mã môn học <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="UpdateDto.Code" type="text" placeholder="Ví dụ: PRF192"
                           class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-fpt-navy/20 focus:border-fpt-navy/40 text-sm transition-all font-mono uppercase" />
                    <span asp-validation-for="UpdateDto.Code" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <!-- Tên môn học -->
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                        Tên môn học <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="UpdateDto.Name" type="text" placeholder="Ví dụ: Lập trình căn bản"
                           class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-fpt-navy/20 focus:border-fpt-navy/40 text-sm transition-all" />
                    <span asp-validation-for="UpdateDto.Name" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <!-- Tín chỉ + Kỳ CT + Học phí -->
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                            Tín chỉ <span class="text-red-500">*</span>
                        </label>
                        <select asp-for="UpdateDto.Credits"
                                class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-fpt-navy/20 focus:border-fpt-navy/40 text-sm transition-all bg-white">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <option value="@i">@i tín chỉ</option>
                            }
                        </select>
                        <span asp-validation-for="UpdateDto.Credits" class="text-xs text-red-500 mt-1 block"></span>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                            Kỳ chương trình <span class="text-red-500">*</span>
                        </label>
                        <select asp-for="UpdateDto.ProgramSemester"
                                class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-fpt-navy/20 focus:border-fpt-navy/40 text-sm transition-all bg-white">
                            @for (int i = 1; i <= 9; i++)
                            {
                                <option value="@i">Kỳ @i</option>
                            }
                        </select>
                        <span asp-validation-for="UpdateDto.ProgramSemester" class="text-xs text-red-500 mt-1 block"></span>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                            Học phí (VNĐ) <span class="text-red-500">*</span>
                        </label>
                        <input asp-for="UpdateDto.Price" type="number" placeholder="Ví dụ: 6000000" min="0" step="100000"
                               class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-fpt-navy/20 focus:border-fpt-navy/40 text-sm transition-all" />
                        <span asp-validation-for="UpdateDto.Price" class="text-xs text-red-500 mt-1 block"></span>
                    </div>
                </div>

                <!-- Mô tả -->
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                        Mô tả
                    </label>
                    <textarea asp-for="UpdateDto.Description" rows="3" placeholder="Mô tả ngắn về môn học..."
                              class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-fpt-navy/20 focus:border-fpt-navy/40 text-sm transition-all resize-none"></textarea>
                    <span asp-validation-for="UpdateDto.Description" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <!-- Trạng thái -->
                <div>
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" asp-for="UpdateDto.IsActive" value="true"
                               class="rounded text-fpt-navy w-4 h-4" />
                        <span class="text-sm font-semibold text-slate-700">Đang hoạt động</span>
                    </label>
                </div>

                <!-- Môn tiên quyết -->
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                        Môn tiên quyết
                    </label>
                    <div class="border border-slate-200 rounded-xl p-3 max-h-48 overflow-y-auto space-y-1.5">
                        @if (Model.AllSubjects.Any())
                        {
                            @foreach (var subject in Model.AllSubjects)
                            {
                                var isPrereq = Model.UpdateDto.PrerequisiteSubjectIds?.Contains(subject.Id) ?? false;
                                <label class="flex items-center gap-2 cursor-pointer hover:bg-slate-50 rounded-lg px-2 py-1">
                                    <input type="checkbox" name="UpdateDto.PrerequisiteSubjectIds" value="@subject.Id"
                                           @(isPrereq ? "checked" : "") class="rounded text-fpt-navy prerequisite-checkbox" />
                                    <span class="text-xs font-mono text-fpt-navy">@subject.Code</span>
                                    <span class="text-sm text-slate-700">@subject.Name</span>
                                </label>
                            }
                        }
                        else
                        {
                            <p class="text-xs text-slate-400 text-center py-2">Chưa có môn học nào</p>
                        }
                    </div>
                </div>

                <!-- Hidden input to store selected prerequisite IDs -->
                <input type="hidden" id="prerequisiteIds" name="prerequisiteIds" value="" />

                <!-- Divider -->
                <hr class="border-slate-100" />

                <!-- Actions -->
                <div class="flex items-center justify-between pt-1">
                    <a href="/Admin/Subjects"
                       class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl border border-slate-200 text-sm font-semibold text-slate-600 hover:bg-slate-50 transition-colors">
                        <i data-lucide="arrow-left" class="w-4 h-4"></i>
                        Hủy bỏ
                    </a>
                    <button type="submit"
                            class="inline-flex items-center gap-2 px-6 py-2.5 bg-fpt-orange hover:bg-orange-500 text-white font-bold rounded-xl text-sm transition-all hover:shadow-lg">
                        <i data-lucide="save" class="w-4 h-4"></i>
                        Cập nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
}

<script>
    // Collect prerequisite subject IDs before form submission
    document.querySelector('form')?.addEventListener('submit', function(e) {
        const checkedBoxes = document.querySelectorAll('.prerequisite-checkbox:checked');
        const ids = Array.from(checkedBoxes).map(cb => cb.value).join(',');
        document.getElementById('prerequisiteIds').value = ids;
    });
</script>
