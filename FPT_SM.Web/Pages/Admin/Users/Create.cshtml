@page
@model FPT_SM.Web.Pages.Admin.Users.CreateModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Thêm người dùng mới";
}

<!-- Breadcrumb -->
<nav class="flex items-center gap-2 text-sm text-slate-400 mb-6" data-aos="fade-down">
    <a href="/Admin/Users" class="hover:text-fpt-navy transition-colors">Quản lý tài khoản</a>
    <i data-lucide="chevron-right" class="w-4 h-4"></i>
    <span class="text-slate-600 font-medium">Thêm người dùng mới</span>
</nav>

<div class="max-w-2xl mx-auto" data-aos="fade-up">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <!-- Card Header -->
        <div class="bg-gradient-to-r from-fpt-navy to-blue-800 px-6 py-5">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center">
                    <i data-lucide="user-plus" class="w-5 h-5 text-white"></i>
                </div>
                <div>
                    <h2 class="text-white font-bold text-lg">Thêm người dùng mới</h2>
                    <p class="text-white/60 text-sm">Điền đầy đủ thông tin bên dưới</p>
                </div>
            </div>
        </div>

        <!-- Form -->
        <form method="post" class="p-6 space-y-5">
            @Html.AntiForgeryToken()

            <!-- Validation Summary -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="bg-red-50 border border-red-200 rounded-xl p-4 flex items-start gap-3">
                    <i data-lucide="alert-circle" class="w-5 h-5 text-red-500 flex-shrink-0 mt-0.5"></i>
                    <div>
                        <p class="text-sm font-semibold text-red-700 mb-1">Vui lòng kiểm tra lại thông tin:</p>
                        <ul class="text-sm text-red-600 space-y-0.5">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <li>• @error.ErrorMessage</li>
                            }
                        </ul>
                    </div>
                </div>
            }

            <!-- Họ và tên -->
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                    Họ và tên <span class="text-red-500">*</span>
                </label>
                <input asp-for="Input.FullName" type="text" placeholder="Nhập họ và tên đầy đủ"
                       class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-fpt-navy/20 focus:border-fpt-navy/40 text-sm transition-all" />
                <span asp-validation-for="Input.FullName" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <!-- Email -->
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                    Email <span class="text-red-500">*</span>
                </label>
                <input asp-for="Input.Email" type="email" placeholder="example@fpt.edu.vn"
                       class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-fpt-navy/20 focus:border-fpt-navy/40 text-sm transition-all" />
                <span asp-validation-for="Input.Email" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <!-- Mật khẩu + Xác nhận -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                        Mật khẩu <span class="text-red-500">*</span>
                    </label>
                    <div class="relative">
                        <input asp-for="Input.Password" type="password" id="passwordInput" placeholder="Tối thiểu 8 ký tự"
                               class="w-full px-4 py-2.5 pr-10 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-fpt-navy/20 focus:border-fpt-navy/40 text-sm transition-all" />
                        <button type="button" onclick="togglePwd('passwordInput', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
                            <i data-lucide="eye" class="w-4 h-4"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.Password" class="text-xs text-red-500 mt-1 block"></span>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                        Xác nhận mật khẩu <span class="text-red-500">*</span>
                    </label>
                    <div class="relative">
                        <input asp-for="Input.ConfirmPassword" type="password" id="confirmInput" placeholder="Nhập lại mật khẩu"
                               class="w-full px-4 py-2.5 pr-10 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-fpt-navy/20 focus:border-fpt-navy/40 text-sm transition-all" />
                        <button type="button" onclick="togglePwd('confirmInput', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
                            <i data-lucide="eye" class="w-4 h-4"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-xs text-red-500 mt-1 block"></span>
                </div>
            </div>

            <!-- Vai trò -->
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                    Vai trò <span class="text-red-500">*</span>
                </label>
                <select asp-for="Input.RoleId" id="roleSelect"
                        class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-fpt-navy/20 focus:border-fpt-navy/40 text-sm bg-white transition-all">
                    <option value="0">-- Chọn vai trò --</option>
                    <option value="1">Admin - Quản trị viên</option>
                    <option value="2">Manager - Quản lý học vụ</option>
                    <option value="3">Teacher - Giảng viên</option>
                    <option value="4">Student - Sinh viên</option>
                </select>
                <span asp-validation-for="Input.RoleId" class="text-xs text-red-500 mt-1 block"></span>
                <!-- Note for Student role -->
                <p id="studentNote" class="hidden mt-2 text-xs text-sky-600 bg-sky-50 border border-sky-200 rounded-lg px-3 py-2 flex items-center gap-1.5">
                    <i data-lucide="info" class="w-3.5 h-3.5"></i>
                    Mã số sinh viên sẽ được tạo tự động khi vai trò là Sinh viên.
                </p>
            </div>

            <!-- Số dư ví ban đầu -->
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                    Số dư ví ban đầu (VND)
                </label>
                <input asp-for="Input.WalletBalance" type="number" min="0" step="1000" placeholder="0"
                       class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-fpt-navy/20 focus:border-fpt-navy/40 text-sm transition-all" />
                <span asp-validation-for="Input.WalletBalance" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <!-- Divider -->
            <hr class="border-slate-100" />

            <!-- Actions -->
            <div class="flex items-center justify-between pt-1">
                <a href="/Admin/Users"
                   class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl border border-slate-200 text-sm font-semibold text-slate-600 hover:bg-slate-50 transition-colors">
                    <i data-lucide="arrow-left" class="w-4 h-4"></i>
                    Hủy bỏ
                </a>
                <button type="submit"
                        class="inline-flex items-center gap-2 px-6 py-2.5 bg-fpt-orange hover:bg-orange-500 text-white font-bold rounded-xl text-sm transition-all hover:shadow-lg">
                    <i data-lucide="save" class="w-4 h-4"></i>
                    Tạo tài khoản
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function togglePwd(inputId, btn) {
        const input = document.getElementById(inputId);
        const isPass = input.type === 'password';
        input.type = isPass ? 'text' : 'password';
        btn.innerHTML = isPass
            ? '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>'
            : '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>';
    }

    // Show/hide student note
    const roleSelect = document.getElementById('roleSelect');
    const studentNote = document.getElementById('studentNote');
    roleSelect?.addEventListener('change', function () {
        studentNote?.classList.toggle('hidden', this.value !== '4');
        if (this.value === '4') lucide.createIcons();
    });

    // Password strength feedback
    const pwd = document.getElementById('passwordInput');
    const confirmPwd = document.getElementById('confirmInput');
    confirmPwd?.addEventListener('input', function () {
        if (this.value && pwd.value && this.value !== pwd.value) {
            this.style.borderColor = '#EF4444';
        } else {
            this.style.borderColor = '';
        }
    });
</script>
}
