@page
@model FPT_SM.Web.Pages.Admin.DashboardModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard - Quản trị viên";
    var data = Model.DashboardData;
}

<style>
    .usage-shell .usage-card {
        background: #fff;
        border: 1px solid #d4d4d8;
        border-radius: 18px;
        box-shadow: none;
    }

    .usage-shell .usage-card:hover {
        transform: translateY(-2px);
    }

    .usage-shell .usage-banner {
        background: #fff;
        border: 1.5px solid #111827;
        border-radius: 18px;
        color: #111827;
    }

    .usage-shell .usage-badge {
        background: #f4f4f5;
        color: #27272a;
    }

    .usage-shell .usage-title {
        color: #111827;
        font-weight: 800;
        letter-spacing: -0.01em;
    }
</style>

<div class="usage-shell space-y-6">

<!-- Stats Cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-5 mb-8">
    <!-- Tổng người dùng -->
    <a href="/Admin/Users" class="usage-card p-5 transition-all cursor-pointer" data-aos="fade-up" data-aos-delay="0">
        <div class="flex items-center justify-between mb-3">
            <div class="w-11 h-11 bg-zinc-100 rounded-xl flex items-center justify-center">
                <i data-lucide="users" class="w-5 h-5 text-zinc-800"></i>
            </div>
            <span class="usage-badge text-xs font-semibold px-2 py-1 rounded-full">+Tổng</span>
        </div>
        <p class="text-slate-500 text-sm font-medium">Tổng người dùng</p>
        <p class="text-3xl font-black text-zinc-900 mt-1">@(data?.TotalUsers.ToString("N0") ?? "—")</p>
        <p class="text-xs text-slate-400 mt-1">@(data?.TotalStudents ?? 0) sinh viên · @(data?.TotalTeachers ?? 0) giáo viên</p>
    </a>

    <!-- Học kỳ đang mở -->
    <a href="/Admin/Semesters" class="usage-card p-5 transition-all cursor-pointer" data-aos="fade-up" data-aos-delay="80">
        <div class="flex items-center justify-between mb-3">
            <div class="w-11 h-11 bg-zinc-100 rounded-xl flex items-center justify-center">
                <i data-lucide="calendar" class="w-5 h-5 text-zinc-800"></i>
            </div>
            <span class="usage-badge text-xs font-semibold px-2 py-1 rounded-full">Đang mở</span>
        </div>
        <p class="text-slate-500 text-sm font-medium">Học kỳ đang mở</p>
        <p class="text-3xl font-black text-zinc-900 mt-1">@(data?.ActiveSemesters ?? 0)</p>
        <p class="text-xs text-slate-400 mt-1">Học kỳ đang diễn ra</p>
    </a>

    <!-- Tổng lớp học -->
    <a href="/Admin/Classes" class="usage-card p-5 transition-all cursor-pointer" data-aos="fade-up" data-aos-delay="160">
        <div class="flex items-center justify-between mb-3">
            <div class="w-11 h-11 bg-zinc-100 rounded-xl flex items-center justify-center">
                <i data-lucide="graduation-cap" class="w-5 h-5 text-zinc-800"></i>
            </div>
            <span class="usage-badge text-xs font-semibold px-2 py-1 rounded-full">Lớp học</span>
        </div>
        <p class="text-slate-500 text-sm font-medium">Tổng lớp học</p>
        <p class="text-3xl font-black text-zinc-900 mt-1">@(data?.TotalClasses.ToString("N0") ?? "—")</p>
        <p class="text-xs text-slate-400 mt-1">@(data?.OngoingClasses ?? 0) lớp đang học</p>
    </a>

    <!-- Sinh viên đang học -->
    <a href="/Admin/Classes" class="usage-card p-5 transition-all cursor-pointer" data-aos="fade-up" data-aos-delay="240">
        <div class="flex items-center justify-between mb-3">
            <div class="w-11 h-11 bg-zinc-100 rounded-xl flex items-center justify-center">
                <i data-lucide="book-open" class="w-5 h-5 text-zinc-800"></i>
            </div>
            <span class="usage-badge text-xs font-semibold px-2 py-1 rounded-full">Đăng ký</span>
        </div>
        <p class="text-slate-500 text-sm font-medium">Sinh viên đang học</p>
        <p class="text-3xl font-black text-zinc-900 mt-1">@(data?.TotalEnrollments.ToString("N0") ?? "—")</p>
        <p class="text-xs text-slate-400 mt-1">Tổng lượt đăng ký môn học</p>
    </a>
</div>

<!-- Revenue Banner -->
<div class="usage-banner p-6 mb-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4" data-aos="fade-up">
    <div>
        <p class="text-zinc-500 text-xs font-medium mb-1 uppercase tracking-wider">Usage Overview</p>
        <p class="usage-title text-4xl">@(data?.TotalRevenue.ToString("N0") ?? "0") ₫</p>
        <p class="text-zinc-500 text-xs mt-1">Tháng này: <span class="font-bold text-zinc-900">@(data?.MonthlyRevenue.ToString("N0") ?? "0") ₫</span></p>
    </div>
    <div class="flex gap-3">
        <a href="/Admin/Semesters?action=create"
           class="flex items-center gap-2 bg-zinc-900 hover:bg-black text-white font-semibold px-4 py-2.5 rounded-xl text-sm transition-all">
            <i data-lucide="plus-circle" class="w-4 h-4"></i>
            Tạo học kỳ mới
        </a>
        <a href="/Admin/Subjects?action=create"
           class="flex items-center gap-2 bg-white hover:bg-zinc-100 text-zinc-800 font-semibold px-4 py-2.5 rounded-xl text-sm transition-all border border-zinc-300">
            <i data-lucide="book-plus" class="w-4 h-4"></i>
            Thêm môn học
        </a>
    </div>
</div>

<!-- Charts Row -->
<div class="grid grid-cols-1 xl:grid-cols-3 gap-6 mb-8">
    <!-- Revenue Line Chart -->
    <div class="xl:col-span-2 usage-card p-6" data-aos="fade-up" data-aos-delay="100">
        <div class="flex items-center justify-between mb-5">
            <div>
                <h3 class="text-base usage-title">Doanh thu theo tháng</h3>
                <p class="text-zinc-500 text-xs mt-0.5">12 tháng gần nhất</p>
            </div>
            <div class="w-9 h-9 bg-zinc-100 rounded-xl flex items-center justify-center border border-zinc-200">
                <i data-lucide="trending-up" class="w-4 h-4 text-zinc-800"></i>
            </div>
        </div>
        <div style="height:220px;">
            <canvas id="revenueChart"></canvas>
        </div>
    </div>

    <!-- Pass/Fail Doughnut Chart -->
    <div class="usage-card p-6" data-aos="fade-up" data-aos-delay="200">
        <div class="flex items-center justify-between mb-5">
            <div>
                <h3 class="text-base usage-title">Tỉ lệ đậu / rớt</h3>
                <p class="text-zinc-500 text-xs mt-0.5">Kỳ hiện tại</p>
            </div>
            <div class="w-9 h-9 bg-zinc-100 rounded-xl flex items-center justify-center border border-zinc-200">
                <i data-lucide="pie-chart" class="w-4 h-4 text-zinc-800"></i>
            </div>
        </div>
        <div style="height:180px;" class="flex items-center justify-center">
            <canvas id="passFailChart"></canvas>
        </div>
        <div class="flex items-center justify-center gap-6 mt-4">
            <div class="flex items-center gap-2">
                <div class="w-3 h-3 rounded-full bg-zinc-900"></div>
                <span class="text-xs text-slate-500">Đậu (@(data?.TotalEnrollments ?? 0))</span>
            </div>
            <div class="flex items-center gap-2">
                <div class="w-3 h-3 rounded-full bg-zinc-300"></div>
                <span class="text-xs text-slate-500">Rớt</span>
            </div>
        </div>
    </div>
</div>

<!-- Bottom Row: Recent Semesters + Recent Transactions -->
<div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
    <!-- Recent Semesters -->
    <div class="usage-card overflow-hidden" data-aos="fade-up" data-aos-delay="100">
        <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
            <h3 class="font-bold text-slate-800">Học kỳ gần đây</h3>
            <a href="/Admin/Semesters" class="text-xs text-zinc-700 hover:underline font-medium">Xem tất cả</a>
        </div>
        <div class="divide-y divide-slate-50">
            @if (data?.RecentSemesters?.Any() == true)
            {
                @foreach (var sem in data.RecentSemesters.Take(5))
                {
                    <div class="px-6 py-3.5 flex items-center justify-between hover:bg-slate-50 transition-colors">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 bg-zinc-100 rounded-lg flex items-center justify-center">
                                <i data-lucide="calendar" class="w-4 h-4 text-zinc-800"></i>
                            </div>
                            <div>
                                <p class="text-sm font-semibold text-slate-700">@sem.Name</p>
                                <p class="text-xs text-slate-400">@sem.StartDate.ToString("dd/MM/yyyy") — @sem.EndDate.ToString("dd/MM/yyyy")</p>
                            </div>
                        </div>
                        <span class="text-xs font-semibold px-2.5 py-1 rounded-full
                            @(sem.StatusColor == "teal" ? "bg-teal-100 text-teal-700" :
                              sem.StatusColor == "sky"  ? "bg-sky-100 text-sky-700" :
                              sem.StatusColor == "red"  ? "bg-red-100 text-red-700" : "bg-slate-100 text-slate-600")">
                            @sem.StatusName
                        </span>
                    </div>
                }
            }
            else
            {
                <div class="px-6 py-8 text-center text-slate-400 text-sm">Chưa có dữ liệu</div>
            }
        </div>
    </div>

    <!-- Recent Transactions -->
    <div class="usage-card overflow-hidden" data-aos="fade-up" data-aos-delay="200">
        <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
            <h3 class="font-bold text-slate-800">Hoạt động gần đây</h3>
            <a href="/Admin/Reports" class="text-xs text-zinc-700 hover:underline font-medium">Xem tất cả</a>
        </div>
        <div class="divide-y divide-slate-50">
            @if (data?.RecentTransactions?.Any() == true)
            {
                @foreach (var tx in data.RecentTransactions.Take(5))
                {
                    <div class="px-6 py-3.5 flex items-center justify-between hover:bg-slate-50 transition-colors">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center
                                @(tx.StatusColor == "teal" ? "bg-teal-100" : tx.StatusColor == "red" ? "bg-red-100" : "bg-amber-100")">
                                <i data-lucide="credit-card" class="w-4 h-4
                                    @(tx.StatusColor == "teal" ? "text-teal-600" : tx.StatusColor == "red" ? "text-red-600" : "text-amber-600")"></i>
                            </div>
                            <div>
                                <p class="text-sm font-medium text-slate-700">@tx.UserName</p>
                                <p class="text-xs text-slate-400">@tx.TypeVN · @tx.CreatedAt.ToString("dd/MM HH:mm")</p>
                            </div>
                        </div>
                        <div class="text-right">
                            <p class="text-sm font-bold text-zinc-900">
                                @(tx.Type == "Deposit" ? "+" : "-")@tx.Amount.ToString("N0")₫
                            </p>
                            <span class="text-xs font-medium
                                @(tx.StatusColor == "teal" ? "text-teal-500" : tx.StatusColor == "red" ? "text-red-500" : "text-amber-500")">
                                @tx.StatusVN
                            </span>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="px-6 py-8 text-center text-slate-400 text-sm">Chưa có giao dịch nào</div>
            }
        </div>
    </div>
</div>
</div>

@section Scripts {
<script>
    const rawData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        (data?.RevenueChart?.Select(r => new { month = r.Month, revenue = r.Revenue }).ToList() as IEnumerable<object>) ?? (IEnumerable<object>)new List<object>()
    ));

    const labels = rawData.map(d => d.month);
    const values = rawData.map(d => d.revenue);
    const total = @(data?.TotalEnrollments ?? 0);
    const passed = Math.round(total * 0.75);
    const failed = total - passed;

    let revenueChartInstance;
    let passFailChartInstance;

    function getThemeTokens() {
        const mystic = document.documentElement.classList.contains('theme-mystic');
        return mystic
            ? {
                line: '#38bdf8',
                fill: 'rgba(56,189,248,0.16)',
                point: '#7dd3fc',
                grid: 'rgba(148,163,184,0.24)',
                tick: '#cbd5e1',
                donutA: '#38bdf8',
                donutB: '#334155',
                donutBorder: '#0f172a'
            }
            : {
                line: '#111827',
                fill: 'rgba(17,24,39,0.08)',
                point: '#111827',
                grid: 'rgba(0,0,0,0.12)',
                tick: '#475569',
                donutA: '#111827',
                donutB: '#d4d4d8',
                donutBorder: '#ffffff'
            };
    }

    function renderDashboardCharts() {
        const tokens = getThemeTokens();

        if (revenueChartInstance) revenueChartInstance.destroy();
        if (passFailChartInstance) passFailChartInstance.destroy();

        const lineCtx = document.getElementById('revenueChart')?.getContext('2d');
        const donutCtx = document.getElementById('passFailChart')?.getContext('2d');
        if (!lineCtx || !donutCtx) return;

        revenueChartInstance = new Chart(lineCtx, {
            type: 'line',
            data: {
                labels: labels.length ? labels : ['T1','T2','T3','T4','T5','T6','T7','T8','T9','T10','T11','T12'],
                datasets: [{
                    label: 'Doanh thu (₫)',
                    data: values.length ? values : Array(12).fill(0),
                    borderColor: tokens.line,
                    backgroundColor: tokens.fill,
                    tension: 0.42,
                    fill: true,
                    pointBackgroundColor: tokens.point,
                    pointBorderWidth: 2,
                    pointBorderColor: '#fff',
                    pointRadius: 4,
                    pointHoverRadius: 8,
                    borderWidth: 2.6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: ctx => ctx.parsed.y.toLocaleString('vi-VN') + ' ₫'
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: tokens.grid },
                        ticks: {
                            color: tokens.tick,
                            callback: v => (v / 1000000).toFixed(0) + 'M',
                            font: { size: 11 }
                        }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { color: tokens.tick, font: { size: 11 } }
                    }
                }
            }
        });

        passFailChartInstance = new Chart(donutCtx, {
            type: 'doughnut',
            data: {
                labels: ['Đậu', 'Rớt'],
                datasets: [{
                    data: [passed || 1, failed || 0],
                    backgroundColor: [tokens.donutA, tokens.donutB],
                    borderWidth: 3,
                    borderColor: tokens.donutBorder,
                    hoverOffset: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '70%',
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: ctx => ctx.label + ': ' + ctx.parsed + ' SV'
                        }
                    }
                }
            }
        });
    }

    renderDashboardCharts();
    window.addEventListener('admin-theme-changed', renderDashboardCharts);
</script>
}
