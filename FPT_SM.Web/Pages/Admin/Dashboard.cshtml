@page
@model FPT_SM.Web.Pages.Admin.DashboardModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard - Quản trị viên";
    var data = Model.DashboardData;
}

<!-- Stats Cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-5 mb-8">
    <!-- Tổng người dùng -->
    <a href="/Admin/Users" class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 hover:shadow-md transition-all hover:scale-105 cursor-pointer" data-aos="fade-up" data-aos-delay="0">
        <div class="flex items-center justify-between mb-3">
            <div class="w-11 h-11 bg-fpt-navy/10 rounded-xl flex items-center justify-center">
                <i data-lucide="users" class="w-5 h-5 text-fpt-navy"></i>
            </div>
            <span class="text-xs font-semibold text-teal-600 bg-teal-50 px-2 py-1 rounded-full">+Tổng</span>
        </div>
        <p class="text-slate-500 text-sm font-medium">Tổng người dùng</p>
        <p class="text-3xl font-black text-fpt-navy mt-1">@(data?.TotalUsers.ToString("N0") ?? "—")</p>
        <p class="text-xs text-slate-400 mt-1">@(data?.TotalStudents ?? 0) sinh viên · @(data?.TotalTeachers ?? 0) giáo viên</p>
    </a>

    <!-- Học kỳ đang mở -->
    <a href="/Admin/Semesters" class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 hover:shadow-md transition-all hover:scale-105 cursor-pointer" data-aos="fade-up" data-aos-delay="80">
        <div class="flex items-center justify-between mb-3">
            <div class="w-11 h-11 bg-sky-100 rounded-xl flex items-center justify-center">
                <i data-lucide="calendar" class="w-5 h-5 text-sky-500"></i>
            </div>
            <span class="text-xs font-semibold text-sky-600 bg-sky-50 px-2 py-1 rounded-full">Đang mở</span>
        </div>
        <p class="text-slate-500 text-sm font-medium">Học kỳ đang mở</p>
        <p class="text-3xl font-black text-sky-600 mt-1">@(data?.ActiveSemesters ?? 0)</p>
        <p class="text-xs text-slate-400 mt-1">Học kỳ đang diễn ra</p>
    </a>

    <!-- Tổng lớp học -->
    <a href="/Admin/Classes" class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 hover:shadow-md transition-all hover:scale-105 cursor-pointer" data-aos="fade-up" data-aos-delay="160">
        <div class="flex items-center justify-between mb-3">
            <div class="w-11 h-11 bg-fpt-orange/10 rounded-xl flex items-center justify-center">
                <i data-lucide="graduation-cap" class="w-5 h-5 text-fpt-orange"></i>
            </div>
            <span class="text-xs font-semibold text-fpt-orange bg-orange-50 px-2 py-1 rounded-full">Lớp học</span>
        </div>
        <p class="text-slate-500 text-sm font-medium">Tổng lớp học</p>
        <p class="text-3xl font-black text-fpt-orange mt-1">@(data?.TotalClasses.ToString("N0") ?? "—")</p>
        <p class="text-xs text-slate-400 mt-1">@(data?.OngoingClasses ?? 0) lớp đang học</p>
    </a>

    <!-- Sinh viên đang học -->
    <a href="/Admin/Classes" class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 hover:shadow-md transition-all hover:scale-105 cursor-pointer" data-aos="fade-up" data-aos-delay="240">
        <div class="flex items-center justify-between mb-3">
            <div class="w-11 h-11 bg-teal-100 rounded-xl flex items-center justify-center">
                <i data-lucide="book-open" class="w-5 h-5 text-teal-500"></i>
            </div>
            <span class="text-xs font-semibold text-teal-600 bg-teal-50 px-2 py-1 rounded-full">Đăng ký</span>
        </div>
        <p class="text-slate-500 text-sm font-medium">Sinh viên đang học</p>
        <p class="text-3xl font-black text-teal-600 mt-1">@(data?.TotalEnrollments.ToString("N0") ?? "—")</p>
        <p class="text-xs text-slate-400 mt-1">Tổng lượt đăng ký môn học</p>
    </a>
</div>

<!-- Revenue Banner -->
<div class="bg-gradient-to-r from-fpt-navy to-blue-700 rounded-2xl p-6 mb-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4" data-aos="fade-up">
    <div>
        <p class="text-white/70 text-sm font-medium mb-1">Tổng doanh thu</p>
        <p class="text-white font-black text-4xl">@(data?.TotalRevenue.ToString("N0") ?? "0") ₫</p>
        <p class="text-white/60 text-xs mt-1">Tháng này: <span class="text-fpt-orange font-bold">@(data?.MonthlyRevenue.ToString("N0") ?? "0") ₫</span></p>
    </div>
    <div class="flex gap-3">
        <a href="/Admin/Semesters?action=create"
           class="flex items-center gap-2 bg-fpt-orange hover:bg-orange-500 text-white font-semibold px-4 py-2.5 rounded-xl text-sm transition-all hover:shadow-lg">
            <i data-lucide="plus-circle" class="w-4 h-4"></i>
            Tạo học kỳ mới
        </a>
        <a href="/Admin/Subjects?action=create"
           class="flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white font-semibold px-4 py-2.5 rounded-xl text-sm transition-all border border-white/20">
            <i data-lucide="book-plus" class="w-4 h-4"></i>
            Thêm môn học
        </a>
    </div>
</div>

<!-- Charts Row -->
<div class="grid grid-cols-1 xl:grid-cols-3 gap-6 mb-8">
    <!-- Revenue Line Chart -->
    <div class="xl:col-span-2 bg-white rounded-2xl p-6 shadow-sm border border-slate-100" data-aos="fade-up" data-aos-delay="100">
        <div class="flex items-center justify-between mb-5">
            <div>
                <h3 class="text-base font-bold text-slate-800">Doanh thu theo tháng</h3>
                <p class="text-slate-400 text-xs mt-0.5">12 tháng gần nhất</p>
            </div>
            <div class="w-9 h-9 bg-fpt-navy/10 rounded-xl flex items-center justify-center">
                <i data-lucide="trending-up" class="w-4 h-4 text-fpt-navy"></i>
            </div>
        </div>
        <div style="height:220px;">
            <canvas id="revenueChart"></canvas>
        </div>
    </div>

    <!-- Pass/Fail Doughnut Chart -->
    <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100" data-aos="fade-up" data-aos-delay="200">
        <div class="flex items-center justify-between mb-5">
            <div>
                <h3 class="text-base font-bold text-slate-800">Tỉ lệ đậu / rớt</h3>
                <p class="text-slate-400 text-xs mt-0.5">Kỳ hiện tại</p>
            </div>
            <div class="w-9 h-9 bg-teal-100 rounded-xl flex items-center justify-center">
                <i data-lucide="pie-chart" class="w-4 h-4 text-teal-500"></i>
            </div>
        </div>
        <div style="height:180px;" class="flex items-center justify-center">
            <canvas id="passFailChart"></canvas>
        </div>
        <div class="flex items-center justify-center gap-6 mt-4">
            <div class="flex items-center gap-2">
                <div class="w-3 h-3 rounded-full bg-teal-400"></div>
                <span class="text-xs text-slate-500">Đậu (@(data?.TotalEnrollments ?? 0))</span>
            </div>
            <div class="flex items-center gap-2">
                <div class="w-3 h-3 rounded-full bg-red-400"></div>
                <span class="text-xs text-slate-500">Rớt</span>
            </div>
        </div>
    </div>
</div>

<!-- Bottom Row: Recent Semesters + Recent Transactions -->
<div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
    <!-- Recent Semesters -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden" data-aos="fade-up" data-aos-delay="100">
        <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
            <h3 class="font-bold text-slate-800">Học kỳ gần đây</h3>
            <a href="/Admin/Semesters" class="text-xs text-fpt-orange hover:underline font-medium">Xem tất cả</a>
        </div>
        <div class="divide-y divide-slate-50">
            @if (data?.RecentSemesters?.Any() == true)
            {
                @foreach (var sem in data.RecentSemesters.Take(5))
                {
                    <div class="px-6 py-3.5 flex items-center justify-between hover:bg-slate-50 transition-colors">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 bg-fpt-navy/10 rounded-lg flex items-center justify-center">
                                <i data-lucide="calendar" class="w-4 h-4 text-fpt-navy"></i>
                            </div>
                            <div>
                                <p class="text-sm font-semibold text-slate-700">@sem.Name</p>
                                <p class="text-xs text-slate-400">@sem.StartDate.ToString("dd/MM/yyyy") — @sem.EndDate.ToString("dd/MM/yyyy")</p>
                            </div>
                        </div>
                        <span class="text-xs font-semibold px-2.5 py-1 rounded-full
                            @(sem.StatusColor == "teal" ? "bg-teal-100 text-teal-700" :
                              sem.StatusColor == "sky"  ? "bg-sky-100 text-sky-700" :
                              sem.StatusColor == "red"  ? "bg-red-100 text-red-700" : "bg-slate-100 text-slate-600")">
                            @sem.StatusName
                        </span>
                    </div>
                }
            }
            else
            {
                <div class="px-6 py-8 text-center text-slate-400 text-sm">Chưa có dữ liệu</div>
            }
        </div>
    </div>

    <!-- Recent Transactions -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden" data-aos="fade-up" data-aos-delay="200">
        <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
            <h3 class="font-bold text-slate-800">Hoạt động gần đây</h3>
            <a href="/Admin/Reports" class="text-xs text-fpt-orange hover:underline font-medium">Xem tất cả</a>
        </div>
        <div class="divide-y divide-slate-50">
            @if (data?.RecentTransactions?.Any() == true)
            {
                @foreach (var tx in data.RecentTransactions.Take(5))
                {
                    <div class="px-6 py-3.5 flex items-center justify-between hover:bg-slate-50 transition-colors">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center
                                @(tx.StatusColor == "teal" ? "bg-teal-100" : tx.StatusColor == "red" ? "bg-red-100" : "bg-amber-100")">
                                <i data-lucide="credit-card" class="w-4 h-4
                                    @(tx.StatusColor == "teal" ? "text-teal-600" : tx.StatusColor == "red" ? "text-red-600" : "text-amber-600")"></i>
                            </div>
                            <div>
                                <p class="text-sm font-medium text-slate-700">@tx.UserName</p>
                                <p class="text-xs text-slate-400">@tx.TypeVN · @tx.CreatedAt.ToString("dd/MM HH:mm")</p>
                            </div>
                        </div>
                        <div class="text-right">
                            <p class="text-sm font-bold @(tx.Type == "Deposit" ? "text-teal-600" : "text-fpt-navy")">
                                @(tx.Type == "Deposit" ? "+" : "-")@tx.Amount.ToString("N0")₫
                            </p>
                            <span class="text-xs font-medium
                                @(tx.StatusColor == "teal" ? "text-teal-500" : tx.StatusColor == "red" ? "text-red-500" : "text-amber-500")">
                                @tx.StatusVN
                            </span>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="px-6 py-8 text-center text-slate-400 text-sm">Chưa có giao dịch nào</div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Revenue Line Chart
    (function () {
        const ctx = document.getElementById('revenueChart')?.getContext('2d');
        if (!ctx) return;

        const rawData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            (data?.RevenueChart?.Select(r => new { month = r.Month, revenue = r.Revenue }).ToList() as IEnumerable<object>) ?? (IEnumerable<object>)new List<object>()
        ));

        const labels = rawData.map(d => d.month);
        const values = rawData.map(d => d.revenue);

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels.length ? labels : ['T1','T2','T3','T4','T5','T6','T7','T8','T9','T10','T11','T12'],
                datasets: [{
                    label: 'Doanh thu (₫)',
                    data: values.length ? values : Array(12).fill(0),
                    borderColor: '#FF6B35',
                    backgroundColor: 'rgba(255,107,53,0.08)',
                    tension: 0.4,
                    fill: true,
                    pointBackgroundColor: '#FF6B35',
                    pointRadius: 4,
                    pointHoverRadius: 7,
                    borderWidth: 2.5
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: ctx => ctx.parsed.y.toLocaleString('vi-VN') + ' ₫'
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(0,0,0,0.04)' },
                        ticks: {
                            callback: v => (v / 1000000).toFixed(0) + 'M',
                            font: { size: 11 }
                        }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { font: { size: 11 } }
                    }
                }
            }
        });
    })();

    // Pass/Fail Doughnut Chart
    (function () {
        const ctx = document.getElementById('passFailChart')?.getContext('2d');
        if (!ctx) return;
        const total = @(data?.TotalEnrollments ?? 0);
        const passed = Math.round(total * 0.75);
        const failed = total - passed;
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Đậu', 'Rớt'],
                datasets: [{
                    data: [passed || 1, failed || 0],
                    backgroundColor: ['#14B8A6', '#EF4444'],
                    borderWidth: 3,
                    borderColor: '#fff',
                    hoverOffset: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '70%',
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: ctx => ctx.label + ': ' + ctx.parsed + ' SV'
                        }
                    }
                }
            }
        });
    })();
</script>
}
