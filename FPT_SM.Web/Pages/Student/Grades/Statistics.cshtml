@page
@model FPT_SM.Web.Pages.Student.Grades.StatisticsModel
@using System.Text.Json
@{
    Layout = "_StudentLayout";
    ViewData["Title"] = "Thống kê học tập";

    var semesterStats = Model.GetSemesterStats();
    var (overallGpa, totalPassed, totalFailed, totalCredits, progressPercent) = Model.GetOverallStats();
    var (studentGpa, classAverage, comparison) = Model.GetGpaComparison();

    var semesterLabels = semesterStats.Select(s => s.semesterName).ToList();
    var semesterGpas = semesterStats.Select(s => (double)s.gpa).ToList();
    var semesterPassed = semesterStats.Select(s => s.passed).ToList();
    var semesterFailed = semesterStats.Select(s => s.failed).ToList();
}

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6" data-aos="fade-down">
    <div>
        <h2 class="text-2xl font-black text-fpt-navy">Thống kê học tập</h2>
        <p class="text-slate-500 text-sm mt-1">Phân tích hiệu suất và tiến độ học tập</p>
    </div>
    <form method="post" asp-page-handler="ExportPdf" class="flex gap-2">
        <button type="submit" class="inline-flex items-center gap-2 bg-slate-800 hover:bg-slate-900 text-white font-semibold px-5 py-2.5 rounded-xl text-sm transition-all">
            <i data-lucide="download" class="w-4 h-4"></i>
            Tải PDF
        </button>
    </form>
</div>

<!-- Overall Statistics Cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 mb-6" data-aos="fade-up" data-aos-delay="50">
    <!-- Overall GPA -->
    <div class="bg-gradient-to-br from-fpt-navy to-blue-800 rounded-xl p-4 text-white">
        <p class="text-xs text-blue-200 mb-2">GPA Trung bình</p>
        <p class="text-3xl font-black">@overallGpa.ToString("F2")</p>
        <p class="text-xs text-blue-100 mt-1">/ 10.0</p>
    </div>

    <!-- Total Passed -->
    <div class="bg-gradient-to-br from-teal-400 to-teal-600 rounded-xl p-4 text-white">
        <p class="text-xs text-teal-100 mb-2">Môn đậu</p>
        <p class="text-3xl font-black">@totalPassed</p>
        <p class="text-xs text-teal-100 mt-1">Subjects passed</p>
    </div>

    <!-- Total Failed -->
    <div class="bg-gradient-to-br from-red-400 to-red-600 rounded-xl p-4 text-white">
        <p class="text-xs text-red-100 mb-2">Môn rớt</p>
        <p class="text-3xl font-black">@totalFailed</p>
        <p class="text-xs text-red-100 mt-1">Failed subjects</p>
    </div>

    <!-- Total Credits -->
    <div class="bg-gradient-to-br from-purple-400 to-purple-600 rounded-xl p-4 text-white">
        <p class="text-xs text-purple-100 mb-2">Tín chỉ tích lũy</p>
        <p class="text-3xl font-black">@totalCredits</p>
        <p class="text-xs text-purple-100 mt-1">Credit hours</p>
    </div>

    <!-- Progress -->
    <div class="bg-gradient-to-br from-fpt-orange to-orange-600 rounded-xl p-4 text-white">
        <p class="text-xs text-orange-100 mb-2">Tiến độ</p>
        <p class="text-3xl font-black">@progressPercent.ToString("F0")%</p>
        <p class="text-xs text-orange-100 mt-1">Program</p>
    </div>
</div>

<!-- Charts Section -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <!-- GPA Trend Chart -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6" data-aos="fade-up">
        <h3 class="text-lg font-bold text-slate-800 mb-4">GPA theo kỳ học</h3>
        <canvas id="gpaChart" height="300"></canvas>
    </div>

    <!-- Pass/Fail Chart -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6" data-aos="fade-up">
        <h3 class="text-lg font-bold text-slate-800 mb-4">Tỉ lệ đậu/rớt</h3>
        <canvas id="passFailChart" height="300"></canvas>
    </div>
</div>

<!-- Comparison Section -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <!-- Student vs Class Average -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6" data-aos="fade-up">
        <h3 class="text-lg font-bold text-slate-800 mb-4">So sánh với lớp</h3>
        <div class="space-y-4">
            <div>
                <div class="flex items-end justify-between mb-2">
                    <span class="text-sm font-semibold text-slate-700">GPA của bạn</span>
                    <span class="text-lg font-black text-fpt-navy">@studentGpa.ToString("F2")</span>
                </div>
                <div class="w-full bg-slate-200 rounded-full h-3">
                    <div class="bg-fpt-navy rounded-full h-3" style="width: @(studentGpa * 10)%"></div>
                </div>
            </div>

            <div>
                <div class="flex items-end justify-between mb-2">
                    <span class="text-sm font-semibold text-slate-400">Trung bình lớp</span>
                    <span class="text-lg font-semibold text-slate-400">@classAverage.ToString("F2")</span>
                </div>
                <div class="w-full bg-slate-200 rounded-full h-3">
                    <div class="bg-slate-400 rounded-full h-3" style="width: @(classAverage * 10)%"></div>
                </div>
            </div>

            <div class="mt-4 px-4 py-3 rounded-lg bg-blue-50 border border-blue-200">
                <p class="text-sm">
                    <span class="font-semibold text-blue-900">GPA của bạn @comparison trung bình lớp</span>
                    <br>
                    <span class="text-blue-700">Chênh lệch: <strong>@(Math.Abs(studentGpa - classAverage).ToString("F2"))</strong></span>
                </p>
            </div>
        </div>
    </div>

    <!-- Progress Information -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6" data-aos="fade-up">
        <h3 class="text-lg font-bold text-slate-800 mb-4">Tiến độ học tập</h3>
        <div class="space-y-3">
            <div>
                <div class="flex items-center justify-between mb-2">
                    <span class="text-sm font-medium text-slate-700">Hoàn thành chương trình</span>
                    <span class="text-sm font-bold text-fpt-orange">@progressPercent.ToString("F0")%</span>
                </div>
                <div class="w-full bg-slate-200 rounded-full h-4">
                    <div class="bg-gradient-to-r from-fpt-orange to-orange-500 rounded-full h-4 transition-all"
                         style="width: @progressPercent%"></div>
                </div>
            </div>

            <div class="mt-4 p-3 rounded-lg bg-amber-50 border border-amber-200">
                <p class="text-xs text-amber-900">
                    <span class="font-semibold">ℹ️ Thông tin:</span> Bạn đã hoàn thành <strong>@(totalPassed + totalFailed)</strong> môn
                    trong khoảng <strong>40 môn</strong> của chương trình 4 năm.
                </p>
            </div>

            <div class="mt-3 grid grid-cols-2 gap-2">
                <div class="p-3 bg-teal-50 rounded-lg border border-teal-200">
                    <p class="text-xs text-teal-700">Môn đậu</p>
                    <p class="text-2xl font-bold text-teal-900">@totalPassed</p>
                </div>
                <div class="p-3 bg-red-50 rounded-lg border border-red-200">
                    <p class="text-xs text-red-700">Môn rớt</p>
                    <p class="text-2xl font-bold text-red-900">@totalFailed</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Semester Detail Table -->
@if (semesterStats.Any())
{
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden" data-aos="fade-up">
        <div class="px-6 py-4 border-b border-slate-100">
            <h3 class="font-bold text-slate-800">Chi tiết theo kỳ học</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="bg-slate-50 text-slate-500 text-xs font-semibold uppercase tracking-wider">
                    <tr>
                        <th class="px-4 py-3 text-left">Kỳ học</th>
                        <th class="px-4 py-3 text-center">GPA</th>
                        <th class="px-4 py-3 text-center">Đậu</th>
                        <th class="px-4 py-3 text-center">Rớt</th>
                        <th class="px-4 py-3 text-center">% Đậu</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @foreach (var (semesterName, gpa, passed, failed) in semesterStats)
                    {
                        var total = passed + failed;
                        var passRate = total > 0 ? (passed * 100 / total) : 0;
                        var passRateColor = passRate >= 80 ? "text-teal-600" : passRate >= 60 ? "text-amber-600" : "text-red-600";

                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-4 py-3 font-semibold text-slate-900">@semesterName</td>
                            <td class="px-4 py-3 text-center">
                                <span class="inline-block px-3 py-1 rounded-full bg-blue-100 text-blue-900 font-bold">
                                    @gpa.ToString("F2")
                                </span>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="inline-block px-2 py-1 rounded bg-teal-100 text-teal-900 font-semibold">
                                    @passed
                                </span>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="inline-block px-2 py-1 rounded bg-red-100 text-red-900 font-semibold">
                                    @failed
                                </span>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="font-semibold @passRateColor">@passRate%</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
<script>
    // GPA Trend Line Chart
    const gpaCtx = document.getElementById('gpaChart');
    new Chart(gpaCtx, {
        type: 'line',
        data: {
            labels: @Html.Raw(JsonSerializer.Serialize(semesterLabels)),
            datasets: [{
                label: 'GPA',
                borderColor: '#002E5D',
                backgroundColor: 'rgba(0,46,93,0.1)',
                data: @Html.Raw(JsonSerializer.Serialize(semesterGpas)),
                tension: 0.4,
                fill: true,
                pointBackgroundColor: '#002E5D',
                pointBorderColor: '#fff',
                pointBorderWidth: 2,
                pointRadius: 5,
                pointHoverRadius: 7
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    display: true,
                    position: 'top'
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    max: 10,
                    ticks: {
                        callback: value => value.toFixed(1)
                    }
                }
            }
        }
    });

    // Pass/Fail Stacked Bar Chart
    const passFailCtx = document.getElementById('passFailChart');
    new Chart(passFailCtx, {
        type: 'bar',
        data: {
            labels: @Html.Raw(JsonSerializer.Serialize(semesterLabels)),
            datasets: [
                {
                    label: 'Đậu',
                    backgroundColor: '#14B8A6',
                    data: @Html.Raw(JsonSerializer.Serialize(semesterPassed))
                },
                {
                    label: 'Rớt',
                    backgroundColor: '#EF4444',
                    data: @Html.Raw(JsonSerializer.Serialize(semesterFailed))
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            indexAxis: 'x',
            scales: {
                x: {
                    stacked: true
                },
                y: {
                    stacked: true,
                    beginAtZero: true
                }
            }
        }
    });
</script>
}
