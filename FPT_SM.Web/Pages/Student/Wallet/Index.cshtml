@page
@model FPT_SM.Web.Pages.Student.Wallet.IndexModel
@{
    Layout = "_StudentLayout";
    ViewData["Title"] = "Ví tiền";
    var totalPages = (int)Math.Ceiling((double)Model.TotalTransactions / Model.PageSize);
}

<!-- Hero Banner -->
<div class="bg-gradient-to-r from-fpt-navy via-blue-800 to-fpt-orange rounded-2xl p-6 mb-6 relative overflow-hidden" data-aos="fade-down">
    <div class="absolute top-0 right-0 w-56 h-56 bg-white/5 rounded-full -translate-y-1/3 translate-x-1/4"></div>
    <div class="absolute bottom-0 left-20 w-32 h-32 bg-fpt-orange/20 rounded-full translate-y-1/2"></div>
    <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <div class="flex items-center gap-2 mb-1">
                <div class="w-8 h-8 bg-white/20 rounded-xl flex items-center justify-center">
                    <i data-lucide="wallet" class="w-4 h-4 text-white"></i>
                </div>
                <p class="text-white/70 text-sm font-medium">Ví tiền của tôi</p>
            </div>
            <p class="text-white/60 text-xs mt-1">@(Model.Wallet?.FullName ?? Model.CurrentFullName)</p>
        </div>
        <div class="text-right">
            <p class="text-white/60 text-xs mb-1">Số dư hiện tại</p>
            <p id="wallet-balance" class="text-white font-black text-4xl tracking-tight">
                @((Model.Wallet?.Balance ?? 0).ToString("N0")) ₫
            </p>
            <p class="text-white/50 text-xs mt-1">Cập nhật theo thời gian thực</p>
        </div>
    </div>
</div>

@if (ViewData["SuccessMessage"] != null)
{
    <div class="mb-4 bg-teal-50 border border-teal-200 text-teal-800 px-4 py-3 rounded-xl flex items-center gap-2" data-aos="fade-in">
        <i data-lucide="check-circle-2" class="w-4 h-4 flex-shrink-0"></i>
        <span class="text-sm font-medium">@ViewData["SuccessMessage"]</span>
    </div>
}
@if (ViewData["ErrorMessage"] != null)
{
    <div class="mb-4 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-xl flex items-center gap-2" data-aos="fade-in">
        <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0"></i>
        <span class="text-sm font-medium">@ViewData["ErrorMessage"]</span>
    </div>
}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Nạp tiền -->
    <div class="lg:col-span-1" data-aos="fade-right">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
            <div class="px-5 py-4 border-b border-slate-100">
                <h3 class="font-bold text-slate-800 flex items-center gap-2">
                    <i data-lucide="plus-circle" class="w-5 h-5 text-fpt-orange"></i>
                    Nạp tiền qua VNPay
                </h3>
            </div>
            <div class="p-5">
                <form method="post" asp-page-handler="Deposit" id="depositForm">
                    <div class="mb-4">
                        <p class="text-slate-600 text-sm mb-3 font-medium">Chọn số tiền nạp:</p>
                        <div class="grid grid-cols-2 gap-2">
                            @foreach (var amt in new[] { 1000000m, 2000000m, 5000000m, 10000000m, 20000000m })
                            {
                                <label class="quick-amount-label flex items-center justify-center gap-1.5 bg-slate-50 hover:bg-fpt-navy/5 border-2 border-slate-200 hover:border-fpt-navy rounded-xl px-3 py-2.5 cursor-pointer transition-all text-sm font-semibold text-slate-700 text-center">
                                    <input type="radio" name="quickAmount" value="@amt" class="hidden quick-amount-radio" />
                                    @(amt.ToString("N0")) ₫
                                </label>
                            }
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="block text-slate-600 text-sm font-medium mb-1.5">Hoặc nhập số tiền khác:</label>
                        <div class="relative">
                            <input type="number" id="customAmount" name="amount" min="10000" max="100000000" step="1000"
                                   placeholder="Nhập số tiền (VNĐ)"
                                   class="w-full border-2 border-slate-200 focus:border-fpt-navy rounded-xl px-4 py-2.5 text-sm font-medium text-slate-800 outline-none transition-colors pr-12" />
                            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 text-xs font-bold">VNĐ</span>
                        </div>
                        <p class="text-slate-400 text-xs mt-1">Tối thiểu: 10,000 VNĐ</p>
                    </div>

                    <div class="bg-blue-50 rounded-xl p-3 mb-4">
                        <div class="flex items-start gap-2">
                            <i data-lucide="info" class="w-4 h-4 text-blue-500 flex-shrink-0 mt-0.5"></i>
                            <p class="text-blue-700 text-xs">Thanh toán được bảo mật bởi VNPay. Tiền sẽ được cộng vào ví ngay sau khi giao dịch thành công.</p>
                        </div>
                    </div>

                    <!-- Hidden input to preserve page parameter -->
                    <input type="hidden" name="Page" value="@Model.Page" />

                    <button type="submit" id="depositBtn"
                            class="w-full bg-gradient-to-r from-fpt-navy to-blue-700 hover:from-blue-700 hover:to-fpt-navy text-white font-bold py-3 px-4 rounded-xl transition-all flex items-center justify-center gap-2 shadow-md hover:shadow-lg">
                        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none">
                            <rect width="24" height="24" rx="4" fill="#0066B3"/>
                            <text x="3" y="16" fill="white" font-size="7" font-weight="bold">VNPay</text>
                        </svg>
                        Nạp tiền qua VNPay
                    </button>
                </form>
            </div>
        </div>

        <!-- Thống kê nhanh -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 mt-4 p-5">
            <h4 class="font-bold text-slate-700 text-sm mb-3">Thống kê giao dịch</h4>
            <div class="space-y-2">
                <div class="flex justify-between items-center text-sm">
                    <span class="text-slate-500">Tổng giao dịch</span>
                    <span class="font-bold text-slate-800">@Model.TotalTransactions</span>
                </div>
                <div class="flex justify-between items-center text-sm">
                    <span class="text-slate-500">Đã nạp</span>
                    <span class="font-bold text-teal-600">
                        @Model.TotalDepositsAmount.ToString("N0") ₫
                    </span>
                </div>
                <div class="flex justify-between items-center text-sm">
                    <span class="text-slate-500">Đã thanh toán</span>
                    <span class="font-bold text-fpt-orange">
                        @Model.TotalPaymentsAmount.ToString("N0") ₫
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Lịch sử giao dịch -->
    <div class="lg:col-span-2" data-aos="fade-left">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
            <div class="px-5 py-4 border-b border-slate-100 flex items-center justify-between">
                <h3 class="font-bold text-slate-800 flex items-center gap-2">
                    <i data-lucide="history" class="w-5 h-5 text-fpt-navy"></i>
                    Lịch sử giao dịch
                </h3>
                <span class="text-xs text-slate-500 bg-slate-100 px-2.5 py-1 rounded-full font-medium">
                    @Model.TotalTransactions giao dịch
                </span>
            </div>

            @if (!Model.Transactions.Any())
            {
                <div class="flex flex-col items-center justify-center py-16 text-slate-400">
                    <i data-lucide="inbox" class="w-12 h-12 mb-3 opacity-30"></i>
                    <p class="font-medium">Chưa có giao dịch nào</p>
                    <p class="text-sm">Hãy nạp tiền để bắt đầu sử dụng ví</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="bg-slate-50 text-slate-500 text-xs font-semibold uppercase tracking-wide">
                                <th class="px-4 py-3 text-left">Mô tả</th>
                                <th class="px-4 py-3 text-right">Số tiền</th>
                                <th class="px-4 py-3 text-center">Loại</th>
                                <th class="px-4 py-3 text-center">Trạng thái</th>
                                <th class="px-4 py-3 text-right">Ngày</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-50">
                            @foreach (var tx in Model.Transactions)
                            {
                                <tr class="hover:bg-slate-50/50 transition-colors">
                                    <td class="px-4 py-3">
                                        <div class="flex items-center gap-2.5">
                                            <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0
                                                @(tx.Type == "Deposit" ? "bg-teal-100" : tx.Type == "Refund" ? "bg-sky-100" : "bg-orange-100")">
                                                @if (tx.Type == "Deposit")
                                                {
                                                    <i data-lucide="arrow-down-circle" class="w-4 h-4 text-teal-600"></i>
                                                }
                                                else if (tx.Type == "Refund")
                                                {
                                                    <i data-lucide="rotate-ccw" class="w-4 h-4 text-sky-600"></i>
                                                }
                                                else
                                                {
                                                    <i data-lucide="arrow-up-circle" class="w-4 h-4 text-orange-600"></i>
                                                }
                                            </div>
                                            <div>
                                                <p class="font-medium text-slate-800 line-clamp-1">@(tx.Description ?? "Giao dịch")</p>
                                                @if (!string.IsNullOrEmpty(tx.OrderId))
                                                {
                                                    <p class="text-slate-400 text-xs">@tx.OrderId</p>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-4 py-3 text-right">
                                        <span class="font-bold @(tx.Type == "TuitionPayment" ? "text-red-600" : "text-teal-600")">
                                            @(tx.Type == "TuitionPayment" ? "-" : "+")@tx.Amount.ToString("N0") ₫
                                        </span>
                                    </td>
                                    <td class="px-4 py-3 text-center">
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold
                                            @(tx.Type == "Deposit" ? "bg-sky-100 text-sky-700" :
                                              tx.Type == "Refund" ? "bg-blue-100 text-blue-700" :
                                              "bg-orange-100 text-orange-700")">
                                            @tx.TypeVN
                                        </span>
                                    </td>
                                    <td class="px-4 py-3 text-center">
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold
                                            @(tx.Status == "Success" ? "bg-teal-100 text-teal-700" :
                                              tx.Status == "Failed" ? "bg-red-100 text-red-700" :
                                              "bg-amber-100 text-amber-700")">
                                            <span class="w-1.5 h-1.5 rounded-full mr-1.5 
                                                @(tx.Status == "Success" ? "bg-teal-500" :
                                                  tx.Status == "Failed" ? "bg-red-500" : "bg-amber-500")"></span>
                                            @tx.StatusVN
                                        </span>
                                    </td>
                                    <td class="px-4 py-3 text-right text-slate-500 text-xs whitespace-nowrap">
                                        @tx.CreatedAt.ToString("dd/MM/yyyy")<br />
                                        <span class="text-slate-400">@tx.CreatedAt.ToString("HH:mm")</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                @if (totalPages > 1)
                {
                    <div class="px-5 py-4 border-t border-slate-100 flex items-center justify-between">
                        <p class="text-xs text-slate-500">
                            Trang @Model.CurrentPage / @totalPages &nbsp;·&nbsp; @Model.TotalTransactions giao dịch
                        </p>
                        <div class="flex gap-1">
                            @if (Model.CurrentPage > 1)
                            {
                                <a href="/Student/Wallet?Page=@(Model.CurrentPage - 1)"
                                   class="px-3 py-1.5 rounded-lg bg-slate-100 hover:bg-fpt-navy hover:text-white text-slate-700 text-xs font-medium transition-colors">
                                    ← Trước
                                </a>
                            }
                            @for (int p = Math.Max(1, Model.CurrentPage - 2); p <= Math.Min(totalPages, Model.CurrentPage + 2); p++)
                            {
                                <a href="/Student/Wallet?Page=@p"
                                   class="px-3 py-1.5 rounded-lg text-xs font-bold transition-colors
                                   @(p == Model.CurrentPage ? "bg-fpt-navy text-white" : "bg-slate-100 hover:bg-fpt-navy/10 text-slate-700")">
                                    @p
                                </a>
                            }
                            @if (Model.CurrentPage < totalPages)
                            {
                                <a href="/Student/Wallet?Page=@(Model.CurrentPage + 1)"
                                   class="px-3 py-1.5 rounded-lg bg-slate-100 hover:bg-fpt-navy hover:text-white text-slate-700 text-xs font-medium transition-colors">
                                    Sau →
                                </a>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
<script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
<script>
    // Quick amount selection
    document.querySelectorAll('.quick-amount-radio').forEach(radio => {
        radio.addEventListener('change', function () {
            document.querySelectorAll('.quick-amount-label').forEach(l => {
                l.classList.remove('border-fpt-navy', 'bg-fpt-navy/10', 'text-fpt-navy');
                l.classList.add('border-slate-200', 'bg-slate-50', 'text-slate-700');
            });
            const label = this.closest('.quick-amount-label');
            label.classList.add('border-fpt-navy', 'bg-fpt-navy/10', 'text-fpt-navy');
            label.classList.remove('border-slate-200', 'bg-slate-50', 'text-slate-700');
            document.getElementById('customAmount').value = this.value;
        });
    });

    // SignalR
    const userId = @(ViewData["UserId"] ?? "0");
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/notificationHub")
        .withAutomaticReconnect()
        .build();

    connection.on("WalletUpdated", function (newBalance) {
        const el = document.getElementById('wallet-balance');
        if (el) el.textContent = Number(newBalance).toLocaleString('vi-VN') + ' ₫';
        showToast('Ví tiền đã được cập nhật! Số dư mới: ' + Number(newBalance).toLocaleString('vi-VN') + ' ₫', 'success');
        // Preserve current page in URL when reloading
        const currentUrl = new URL(window.location);
        const currentPage = currentUrl.searchParams.get('Page') || '1';
        setTimeout(() => {
            window.location.href = currentUrl.origin + currentUrl.pathname + '?Page=' + currentPage;
        }, 2000);
    });

    connection.start().then(() => {
        connection.invoke("JoinGroup", "student_" + userId);
    }).catch(console.error);

    function showToast(message, type) {
        const colors = { success: 'bg-teal-600', error: 'bg-red-600', info: 'bg-fpt-navy' };
        const toast = document.createElement('div');
        toast.className = `fixed top-5 right-5 z-50 ${colors[type] || colors.info} text-white px-5 py-3 rounded-xl shadow-xl text-sm font-medium flex items-center gap-2 transition-all`;
        toast.innerHTML = `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>${message}`;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 4000);
    }
</script>
}
