@page
@model FPT_SM.Web.Pages.Student.Quizzes.IndexModel
@{
    Layout = "_StudentLayout";
    ViewData["Title"] = "Quiz của tôi";
}

<div class="mb-6" data-aos="fade-down">
    <h1 class="text-2xl font-black text-fpt-navy">Quiz của tôi</h1>
    <p class="text-slate-400 text-sm mt-0.5">Danh sách bài kiểm tra trắc nghiệm</p>
</div>

@if (TempData["Success"] != null)
{
    <div class="bg-teal-50 border border-teal-200 rounded-xl p-4 mb-5 flex items-center gap-3">
        <i data-lucide="check-circle" class="w-5 h-5 text-teal-500 flex-shrink-0"></i>
        <p class="text-teal-700 text-sm font-medium">@TempData["Success"]</p>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-5 flex items-center gap-3">
        <i data-lucide="alert-circle" class="w-5 h-5 text-red-500 flex-shrink-0"></i>
        <p class="text-red-700 text-sm font-medium">@TempData["Error"]</p>
    </div>
}

<!-- Quiz đang mở -->
<div class="mb-8" data-aos="fade-up">
    <div class="flex items-center gap-2 mb-4">
        <div class="w-2 h-6 bg-teal-500 rounded-full"></div>
        <h2 class="font-bold text-slate-800">Quiz đang mở</h2>
        @if (Model.AvailableQuizzes.Any())
        {
            <span class="w-6 h-6 bg-teal-100 text-teal-700 text-xs rounded-full flex items-center justify-center font-bold">
                @Model.AvailableQuizzes.Count
            </span>
        }
    </div>

    @if (Model.AvailableQuizzes.Any())
    {
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
            @foreach (var quiz in Model.AvailableQuizzes)
            {
                var isActive = quiz.IsActive;
                var isUpcoming = quiz.IsUpcoming;
                <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-5 hover:shadow-md transition-all group" data-quiz-id="@quiz.Id">
                    <div class="flex items-start justify-between gap-3 mb-3">
                        <div class="w-10 h-10 bg-teal-100 rounded-xl flex items-center justify-center flex-shrink-0">
                            <i data-lucide="clipboard-list" class="w-5 h-5 text-teal-600"></i>
                        </div>
                        @if (isActive)
                        {
                            <span class="text-xs font-semibold bg-teal-100 text-teal-700 px-2.5 py-1 rounded-full">Đang mở</span>
                        }
                        else if (isUpcoming)
                        {
                            <span class="text-xs font-semibold bg-sky-100 text-sky-700 px-2.5 py-1 rounded-full">Sắp mở</span>
                        }
                    </div>
                    <h3 class="font-bold text-slate-800 mb-1 line-clamp-2">@quiz.Title</h3>
                    <p class="text-xs text-slate-500 mb-1 font-medium">@quiz.SubjectName</p>
                    <p class="text-xs text-slate-400 mb-3">@quiz.ClassName</p>
                    <div class="flex flex-wrap items-center gap-3 text-xs text-slate-400 mb-4">
                        <span class="flex items-center gap-1">
                            <i data-lucide="clock" class="w-3.5 h-3.5"></i>
                            @quiz.DurationMinutes phút
                        </span>
                        <span class="flex items-center gap-1">
                            <i data-lucide="help-circle" class="w-3.5 h-3.5"></i>
                            @quiz.QuestionCount câu
                        </span>
                    </div>
                    <div class="text-xs text-slate-400 mb-4">
                        <p>Từ: @quiz.StartTime.ToString("dd/MM/yyyy HH:mm")</p>
                        <p>Đến: @quiz.EndTime.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                    @if (isActive)
                    {
                        <a href="/Student/Quizzes/Take/@quiz.Id"
                           class="w-full flex items-center justify-center gap-2 bg-teal-500 hover:bg-teal-600 text-white text-sm font-semibold py-2.5 rounded-xl transition-colors">
                            <i data-lucide="play-circle" class="w-4 h-4"></i>
                            Làm bài ngay
                        </a>
                    }
                    else
                    {
                        <button disabled class="w-full flex items-center justify-center gap-2 bg-slate-100 text-slate-400 text-sm font-semibold py-2.5 rounded-xl cursor-not-allowed">
                            <i data-lucide="clock" class="w-4 h-4"></i>
                            Chưa đến giờ
                        </button>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-12 text-center">
            <div class="w-16 h-16 bg-teal-50 rounded-full flex items-center justify-center mx-auto mb-4">
                <i data-lucide="check-circle" class="w-8 h-8 text-teal-400"></i>
            </div>
            <p class="text-slate-600 font-semibold">Không có quiz nào đang mở</p>
            <p class="text-slate-400 text-sm mt-1">Bạn đã hoàn thành tất cả quiz hiện tại</p>
        </div>
    }
</div>

<!-- Quiz đã hoàn thành -->
<div data-aos="fade-up" data-aos-delay="100">
    <div class="flex items-center gap-2 mb-4">
        <div class="w-2 h-6 bg-slate-400 rounded-full"></div>
        <h2 class="font-bold text-slate-800">Quiz đã hoàn thành / hết hạn</h2>
        @if (Model.CompletedQuizzes.Any())
        {
            <span class="w-6 h-6 bg-slate-100 text-slate-600 text-xs rounded-full flex items-center justify-center font-bold">
                @Model.CompletedQuizzes.Count
            </span>
        }
    </div>

    @if (Model.CompletedQuizzes.Any())
    {
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-slate-50 text-left">
                            <th class="px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Tên Quiz</th>
                            <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Môn học</th>
                            <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Thời gian</th>
                            <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Điểm số</th>
                            <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        @foreach (var quiz in Model.CompletedQuizzes)
                        {
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="px-6 py-3.5">
                                    <p class="font-semibold text-slate-700">@quiz.Title</p>
                                </td>
                                <td class="px-4 py-3.5">
                                    <p class="text-slate-500 text-xs">@quiz.SubjectName</p>
                                    <p class="text-slate-400 text-xs">@quiz.ClassName</p>
                                </td>
                                <td class="px-4 py-3.5">
                                    <p class="text-xs text-slate-500">@quiz.DurationMinutes phút · @quiz.QuestionCount câu</p>
                                </td>
                                <td class="px-4 py-3.5">
                                    @if (quiz.HasSubmitted && quiz.StudentScore.HasValue)
                                    {
                                        <span class="font-bold text-fpt-orange text-base">@quiz.StudentScore.Value.ToString("F1")</span>
                                        <span class="text-xs text-slate-400"> điểm</span>
                                    }
                                    else
                                    {
                                        <span class="text-slate-400 text-xs">—</span>
                                    }
                                </td>
                                <td class="px-4 py-3.5">
                                    @if (quiz.HasSubmitted)
                                    {
                                        <span class="text-xs font-semibold bg-teal-100 text-teal-700 px-2.5 py-1 rounded-full">Đã nộp</span>
                                    }
                                    else
                                    {
                                        <span class="text-xs font-semibold bg-slate-100 text-slate-500 px-2.5 py-1 rounded-full">Hết hạn</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-8 text-center">
            <p class="text-slate-400 text-sm">Chưa có quiz nào đã hoàn thành</p>
        </div>
    }
</div>

@section Scripts {
<script>
    // SignalR: listen for new quiz from all enrolled classes
    (async function() {
        try {
            const conn = signalRManager.get('quiz');
            if (!conn) {
                console.warn('Quiz hub not available');
                return;
            }

            // Get all enrolled class IDs from current quizzes
            const classIds = new Set();
            @foreach (var quiz in Model.AvailableQuizzes.Concat(Model.CompletedQuizzes))
            {
                <text>classIds.add(@quiz.ClassId);</text>
            }

            // Join all class groups for this student
            for (const classId of classIds) {
                try {
                    await conn.invoke('JoinGroup', `class_${classId}`);
                    console.log(`Joined quiz group: class_${classId}`);
                } catch (e) {
                    console.warn(`Failed to join class_${classId}:`, e);
                }
            }

            // Listen for quiz events
            conn.on("QuizCreated", async function(data) {
                showToast(`Quiz mới: ${data.title}`, 'info');
                await new Promise(r => setTimeout(r, 1000));
                location.reload();
            });

            conn.on("QuizPublished", function(data) {
                showToast(`Quiz đã được công bố: ${data.title || 'Quiz mới'}`, 'success');
                setTimeout(() => location.reload(), 1000);
            });

            conn.on("QuizDeleted", async function(data) {
                showToast('Quiz đã bị xóa!', 'warning');
                await new Promise(r => setTimeout(r, 1000));
                location.reload();
            });

        } catch(e) {
            console.warn('SignalR quiz error:', e);
        }
    })();
</script>
}
