@page
@model FPT_SM.Web.Pages.Student.Profile.IndexModel
@{
    Layout = "_StudentLayout";
    ViewData["Title"] = "Hồ sơ của tôi";
    var user = Model.User;
    var roleLabel = user?.RoleId switch {
        1 => "Admin",
        2 => "Manager",
        3 => "Giảng viên",
        4 => "Sinh viên",
        _ => user?.RoleName ?? ""
    };
    var roleBadge = user?.RoleId switch {
        1 => "bg-fpt-navy text-white",
        2 => "bg-purple-100 text-purple-700",
        3 => "bg-sky-100 text-sky-700",
        4 => "bg-teal-100 text-teal-700",
        _ => "bg-slate-100 text-slate-600"
    };
}

<!-- Toast from TempData -->
@if (TempData["Success"] != null)
{
    <div id="tempSuccessMsg" class="hidden">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div id="tempErrorMsg" class="hidden">@TempData["Error"]</div>
}

@if (user == null)
{
    <div class="text-center py-20 text-slate-400">
        <i data-lucide="user-x" class="w-12 h-12 mx-auto mb-3 opacity-30"></i>
        <p>Không tải được thông tin người dùng.</p>
    </div>
}
else
{
    <!-- Profile Header -->
    <div class="bg-gradient-to-r from-fpt-navy to-blue-800 rounded-2xl p-6 mb-6 relative overflow-hidden" data-aos="fade-down">
        <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'0.03\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')]"></div>
        <div class="relative flex flex-col sm:flex-row items-start sm:items-center gap-5">
            <!-- Avatar -->
            <div class="relative group">
                @if (!string.IsNullOrEmpty(user.AvatarUrl))
                {
                    <img src="@user.AvatarUrl" id="avatarPreviewImg"
                         class="w-20 h-20 rounded-full object-cover ring-4 ring-white/30" alt="Avatar" />
                }
                else
                {
                    <div id="avatarPlaceholder" class="w-20 h-20 rounded-full bg-fpt-orange flex items-center justify-center text-white text-3xl font-black ring-4 ring-white/30">
                        @user.FullName.FirstOrDefault()
                    </div>
                }
            </div>

            <!-- Info -->
            <div class="flex-1 min-w-0">
                <h1 class="text-white font-black text-2xl truncate">@user.FullName</h1>
                <p class="text-white/70 text-sm mt-0.5">@user.Email</p>
                <div class="flex flex-wrap items-center gap-2 mt-2">
                    <span class="text-xs font-semibold px-2.5 py-1 rounded-full @roleBadge">@roleLabel</span>
                    @if (!string.IsNullOrEmpty(user.RollNumber))
                    {
                        <span class="text-xs font-mono bg-white/10 text-white px-2.5 py-1 rounded-full">@user.RollNumber</span>
                    }
                    <span class="text-xs bg-white/10 text-white/80 px-2.5 py-1 rounded-full">
                        Tham gia: @user.CreatedAt.ToString("dd/MM/yyyy")
                    </span>
                </div>
            </div>

            <!-- Wallet Balance -->
            <div class="bg-white/10 backdrop-blur-sm rounded-xl px-5 py-3 text-right border border-white/20 flex-shrink-0">
                <p class="text-white/60 text-xs font-medium mb-0.5">Số dư ví</p>
                <p class="text-white font-black text-2xl">@user.WalletBalance.ToString("N0")<span class="text-sm font-normal ml-1">₫</span></p>
                <a href="/Student/Wallet" class="text-fpt-orange text-xs hover:underline mt-1 inline-block">Nạp tiền →</a>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <!-- Section 1: Thông tin cá nhân -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden" data-aos="fade-up" data-aos-delay="50">
            <div class="px-6 py-4 border-b border-slate-100 flex items-center gap-3">
                <div class="w-9 h-9 bg-fpt-navy/10 rounded-xl flex items-center justify-center">
                    <i data-lucide="user-circle" class="w-4 h-4 text-fpt-navy"></i>
                </div>
                <div>
                    <h3 class="font-bold text-slate-800">Thông tin cá nhân</h3>
                    <p class="text-xs text-slate-400">Cập nhật tên và ảnh đại diện</p>
                </div>
            </div>

            <form method="post" asp-page-handler="UpdateProfile" class="p-6 space-y-4">
                @Html.AntiForgeryToken()

                @if (ViewData.ModelState.Values.Any(v => v.Errors.Any()) &&
                     ViewData.ModelState.Keys.Any(k => k.StartsWith("ProfileInput")))
                {
                    <div class="bg-red-50 border border-red-200 rounded-xl p-3 text-sm text-red-600">
                        @foreach (var key in ViewData.ModelState.Keys.Where(k => k.StartsWith("ProfileInput")))
                        {
                            foreach (var err in ViewData.ModelState[key]!.Errors)
                            {
                                <p>• @err.ErrorMessage</p>
                            }
                        }
                    </div>
                }

                <!-- Họ và tên -->
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                        Họ và tên <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="ProfileInput.FullName" type="text"
                           class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-fpt-navy/20 text-sm transition-all" />
                    <span asp-validation-for="ProfileInput.FullName" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <!-- Avatar URL -->
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">URL Ảnh đại diện</label>
                    <input asp-for="ProfileInput.AvatarUrl" type="url" placeholder="https://example.com/avatar.jpg"
                           id="avatarUrlInput"
                           class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-fpt-navy/20 text-sm transition-all" />
                    <span asp-validation-for="ProfileInput.AvatarUrl" class="text-xs text-red-500 mt-1 block"></span>
                    <div id="avatarUrlPreview" class="mt-2 hidden">
                        <img id="urlPreviewImg" class="w-14 h-14 rounded-full object-cover ring-2 ring-fpt-orange/30" src="" alt="Preview" />
                    </div>
                </div>

                <button type="submit"
                        class="w-full inline-flex items-center justify-center gap-2 py-2.5 bg-fpt-navy hover:bg-blue-900 text-white font-bold rounded-xl text-sm transition-all hover:shadow-lg">
                    <i data-lucide="save" class="w-4 h-4"></i>
                    Lưu thông tin
                </button>
            </form>
        </div>

        <!-- Section 1b: Upload Avatar file -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden" data-aos="fade-up" data-aos-delay="80">
            <div class="px-6 py-4 border-b border-slate-100 flex items-center gap-3">
                <div class="w-9 h-9 bg-fpt-orange/10 rounded-xl flex items-center justify-center">
                    <i data-lucide="image" class="w-4 h-4 text-fpt-orange"></i>
                </div>
                <div>
                    <h3 class="font-bold text-slate-800">Tải lên ảnh đại diện</h3>
                    <p class="text-xs text-slate-400">JPG, PNG, GIF - tối đa 5MB</p>
                </div>
            </div>

            <form method="post" asp-page-handler="UploadAvatar" enctype="multipart/form-data" class="p-6 space-y-4">
                @Html.AntiForgeryToken()

                <div id="dropZone"
                     class="border-2 border-dashed border-slate-200 rounded-xl p-8 text-center hover:border-fpt-orange transition-colors cursor-pointer"
                     onclick="document.getElementById('avatarFile').click()">
                    <i data-lucide="upload-cloud" class="w-10 h-10 text-slate-300 mx-auto mb-2"></i>
                    <p class="text-sm font-semibold text-slate-500">Kéo thả hoặc click để chọn ảnh</p>
                    <p class="text-xs text-slate-400 mt-1">JPG, PNG, GIF, WEBP · Tối đa 5MB</p>
                    <div id="filePreviewWrapper" class="hidden mt-4">
                        <img id="filePreviewImg" class="w-20 h-20 rounded-full object-cover mx-auto ring-2 ring-fpt-orange/30" src="" alt="Preview" />
                        <p id="fileNameLabel" class="text-xs text-slate-400 mt-2"></p>
                    </div>
                </div>
                <input type="file" name="avatarFile" id="avatarFile" accept="image/jpeg,image/png,image/gif,image/webp" class="hidden" />

                <button type="submit"
                        class="w-full inline-flex items-center justify-center gap-2 py-2.5 bg-fpt-orange hover:bg-orange-500 text-white font-bold rounded-xl text-sm transition-all hover:shadow-lg">
                    <i data-lucide="upload" class="w-4 h-4"></i>
                    Tải lên ảnh
                </button>
            </form>
        </div>

        <!-- Section 2: Đổi mật khẩu -->
        <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden" data-aos="fade-up" data-aos-delay="120">
            <div class="px-6 py-4 border-b border-slate-100 flex items-center gap-3">
                <div class="w-9 h-9 bg-amber-100 rounded-xl flex items-center justify-center">
                    <i data-lucide="key" class="w-4 h-4 text-amber-600"></i>
                </div>
                <div>
                    <h3 class="font-bold text-slate-800">Đổi mật khẩu</h3>
                    <p class="text-xs text-slate-400">Cập nhật mật khẩu đăng nhập của bạn</p>
                </div>
            </div>

            <form method="post" asp-page-handler="ChangePassword" class="p-6">
                @Html.AntiForgeryToken()

                @if (ViewData.ModelState.Values.Any(v => v.Errors.Any()) &&
                     ViewData.ModelState.Keys.Any(k => k.StartsWith("PasswordInput")))
                {
                    <div class="bg-red-50 border border-red-200 rounded-xl p-3 text-sm text-red-600 mb-4">
                        @foreach (var key in ViewData.ModelState.Keys.Where(k => k.StartsWith("PasswordInput")))
                        {
                            foreach (var err in ViewData.ModelState[key]!.Errors)
                            {
                                <p>• @err.ErrorMessage</p>
                            }
                        }
                    </div>
                }

                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                    <!-- Mật khẩu hiện tại -->
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                            Mật khẩu hiện tại <span class="text-red-500">*</span>
                        </label>
                        <div class="relative">
                            <input asp-for="PasswordInput.OldPassword" type="password" id="oldPwdInput" placeholder="••••••••"
                                   class="w-full px-4 py-2.5 pr-10 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-amber-200 text-sm transition-all" />
                            <button type="button" onclick="toggleFieldPwd('oldPwdInput', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400">
                                <i data-lucide="eye" class="w-4 h-4"></i>
                            </button>
                        </div>
                        <span asp-validation-for="PasswordInput.OldPassword" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    <!-- Mật khẩu mới -->
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                            Mật khẩu mới <span class="text-red-500">*</span>
                        </label>
                        <div class="relative">
                            <input asp-for="PasswordInput.NewPassword" type="password" id="newPwdInput2" placeholder="Tối thiểu 8 ký tự"
                                   class="w-full px-4 py-2.5 pr-10 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-amber-200 text-sm transition-all" />
                            <button type="button" onclick="toggleFieldPwd('newPwdInput2', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400">
                                <i data-lucide="eye" class="w-4 h-4"></i>
                            </button>
                        </div>
                        <span asp-validation-for="PasswordInput.NewPassword" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    <!-- Xác nhận mật khẩu mới -->
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                            Xác nhận mật khẩu mới <span class="text-red-500">*</span>
                        </label>
                        <div class="relative">
                            <input asp-for="PasswordInput.ConfirmPassword" type="password" id="confirmPwdInput2" placeholder="Nhập lại mật khẩu mới"
                                   class="w-full px-4 py-2.5 pr-10 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-amber-200 text-sm transition-all" />
                            <button type="button" onclick="toggleFieldPwd('confirmPwdInput2', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400">
                                <i data-lucide="eye" class="w-4 h-4"></i>
                            </button>
                        </div>
                        <span asp-validation-for="PasswordInput.ConfirmPassword" class="text-xs text-red-500 mt-1 block"></span>
                    </div>
                </div>

                <div class="mt-5 flex justify-end">
                    <button type="submit"
                            class="inline-flex items-center gap-2 px-6 py-2.5 bg-amber-500 hover:bg-amber-600 text-white font-bold rounded-xl text-sm transition-all hover:shadow-lg">
                        <i data-lucide="shield-check" class="w-4 h-4"></i>
                        Đổi mật khẩu
                    </button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
<script>
    // Show toasts from TempData
    document.addEventListener('DOMContentLoaded', function () {
        const successEl = document.getElementById('tempSuccessMsg');
        const errorEl   = document.getElementById('tempErrorMsg');
        if (successEl?.textContent.trim()) showToast(successEl.textContent.trim(), 'success');
        if (errorEl?.textContent.trim())   showToast(errorEl.textContent.trim(),   'error');
    });

    // Toggle password visibility
    function toggleFieldPwd(inputId, btn) {
        const input = document.getElementById(inputId);
        const isPass = input.type === 'password';
        input.type = isPass ? 'text' : 'password';
        btn.innerHTML = isPass
            ? '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>'
            : '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>';
    }

    // Avatar URL live preview
    const avatarUrlInput = document.getElementById('avatarUrlInput');
    const avatarUrlPreview = document.getElementById('avatarUrlPreview');
    const urlPreviewImg = document.getElementById('urlPreviewImg');
    avatarUrlInput?.addEventListener('input', function () {
        const val = this.value.trim();
        if (val) {
            urlPreviewImg.src = val;
            avatarUrlPreview.classList.remove('hidden');
            urlPreviewImg.onerror = () => avatarUrlPreview.classList.add('hidden');
        } else {
            avatarUrlPreview.classList.add('hidden');
        }
    });

    // File drop zone
    const fileInput = document.getElementById('avatarFile');
    const dropZone  = document.getElementById('dropZone');
    const filePreviewWrapper = document.getElementById('filePreviewWrapper');
    const filePreviewImg     = document.getElementById('filePreviewImg');
    const fileNameLabel      = document.getElementById('fileNameLabel');

    fileInput?.addEventListener('change', function () {
        const file = this.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = e => {
            filePreviewImg.src = e.target.result;
            fileNameLabel.textContent = file.name + ' (' + (file.size / 1024).toFixed(1) + ' KB)';
            filePreviewWrapper.classList.remove('hidden');
        };
        reader.readAsDataURL(file);
    });

    dropZone?.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('border-fpt-orange'); });
    dropZone?.addEventListener('dragleave', () => dropZone.classList.remove('border-fpt-orange'));
    dropZone?.addEventListener('drop', e => {
        e.preventDefault();
        dropZone.classList.remove('border-fpt-orange');
        const file = e.dataTransfer.files[0];
        if (file && fileInput) {
            const dt = new DataTransfer();
            dt.items.add(file);
            fileInput.files = dt.files;
            fileInput.dispatchEvent(new Event('change'));
        }
    });

    // Password match validation
    const newPwd = document.getElementById('newPwdInput2');
    const confirmPwd = document.getElementById('confirmPwdInput2');
    confirmPwd?.addEventListener('input', function () {
        this.style.borderColor = (this.value && newPwd.value && this.value !== newPwd.value) ? '#EF4444' : '';
    });
</script>
}
