<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FPT Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'fpt-navy': '#002E5D',
                        'fpt-orange': '#FF6B35'
                    }
                }
            }
        }
    </script>
    <script>
        (function () {
            try {
                const theme = localStorage.getItem('admin-theme') || 'playful';
                document.documentElement.classList.add(theme === 'mystic' ? 'theme-mystic' : 'theme-playful');
            } catch (e) {
                document.documentElement.classList.add('theme-playful');
            }
        })();
    </script>
    <style>
        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1rem;
            border-radius: 0.5rem;
            color: rgb(148, 163, 184);
            transition: all 0.2s;
        }
        .sidebar-link:hover {
            background-color: rgba(255, 255, 255, 0.1);
            color: white;
        }
        .sidebar-link.active {
            background-color: #FF6B35;
            color: white;
        }

        html.theme-playful body {
            background:
                radial-gradient(circle at 10% -10%, rgba(253, 186, 116, 0.24), transparent 42%),
                radial-gradient(circle at 95% 8%, rgba(125, 211, 252, 0.18), transparent 36%),
                linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
            color: #111827;
        }

        html.theme-mystic body {
            background:
                radial-gradient(circle at 88% 12%, rgba(56, 189, 248, 0.18), transparent 30%),
                radial-gradient(circle at 14% 88%, rgba(59, 130, 246, 0.16), transparent 32%),
                linear-gradient(180deg, #020617 0%, #0b1120 100%);
            color: #e5e7eb;
        }

        html.theme-mystic .bg-fpt-navy {
            background: linear-gradient(180deg, #020617 0%, #111827 100%) !important;
            border-right: 1px solid rgba(148, 163, 184, 0.2);
        }

        html.theme-playful .bg-fpt-navy {
            background: linear-gradient(180deg, #1e293b 0%, #334155 100%) !important;
        }

        html.theme-mystic .bg-white,
        html.theme-mystic header.bg-white {
            background: rgba(17, 24, 39, 0.82) !important;
            border-color: rgba(71, 85, 105, 0.55) !important;
            color: #e5e7eb !important;
            backdrop-filter: blur(8px);
        }

        html.theme-mystic .text-slate-800,
        html.theme-mystic .text-slate-700,
        html.theme-mystic .text-slate-600,
        html.theme-mystic .text-fpt-navy,
        html.theme-mystic .text-fpt-orange,
        html.theme-mystic .text-zinc-900 {
            color: #f8fafc !important;
        }

        html.theme-mystic .text-slate-500,
        html.theme-mystic .text-slate-400,
        html.theme-mystic .text-zinc-500,
        html.theme-mystic .text-zinc-700 {
            color: #94a3b8 !important;
        }

        html.theme-mystic .border-slate-200,
        html.theme-mystic .border-slate-100,
        html.theme-mystic .border-zinc-300,
        html.theme-mystic .border-zinc-200 {
            border-color: rgba(71, 85, 105, 0.6) !important;
        }

        html.theme-playful .bg-white,
        html.theme-playful header.bg-white {
            box-shadow: 0 10px 24px rgba(2, 6, 23, 0.05) !important;
            border-color: rgba(203, 213, 225, 0.8) !important;
        }

        html.theme-playful .sidebar-link.active {
            background: linear-gradient(135deg, #fb7185 0%, #f97316 100%) !important;
            color: #fff !important;
        }

        html.theme-mystic .sidebar-link.active {
            background: linear-gradient(135deg, #0ea5e9 0%, #6366f1 100%) !important;
            color: #ffffff !important;
            box-shadow: 0 0 0 1px rgba(56, 189, 248, 0.6), 0 0 20px rgba(56, 189, 248, 0.22);
        }

        html.theme-mystic .shadow-sm,
        html.theme-mystic .shadow-xl,
        html.theme-mystic .hover\:shadow-md:hover {
            box-shadow: 0 8px 30px rgba(2, 6, 23, 0.45) !important;
        }

        html.theme-playful .text-fpt-orange,
        html.theme-playful .text-fpt-navy {
            color: #0f172a !important;
        }

        #themeToggle {
            min-width: 138px;
        }
    </style>
</head>
<body class="bg-slate-100 font-sans transition-colors duration-300">
<div class="flex h-screen overflow-hidden">
    <!-- Sidebar -->
    <aside class="w-64 bg-fpt-navy flex flex-col flex-shrink-0 shadow-xl">
        <!-- Logo -->
        <div class="p-6 border-b border-white/10">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-fpt-orange rounded-lg flex items-center justify-center">
                    <span class="text-white font-bold text-lg">F</span>
                </div>
                <div>
                    <p class="text-white font-bold text-base leading-none">FPT System</p>
                    <p class="text-slate-400 text-xs mt-1">Admin Panel</p>
                </div>
            </div>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 p-4 space-y-1 overflow-y-auto">
            <p class="text-slate-500 text-xs font-semibold uppercase tracking-wider px-4 mb-2">Tổng quan</p>
            <a href="/Admin/Dashboard" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Dashboard") == true ? "active" : "")">
                <i data-lucide="layout-dashboard" class="w-5 h-5"></i>
                <span>Dashboard</span>
            </a>

            <p class="text-slate-500 text-xs font-semibold uppercase tracking-wider px-4 mb-2 mt-4">Quản lý</p>
            <a href="/Admin/Users" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("User") == true ? "active" : "")">
                <i data-lucide="users" class="w-5 h-5"></i>
                <span>Người dùng</span>
            </a>
            <a href="/Admin/Semesters" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Semester") == true ? "active" : "")">
                <i data-lucide="calendar" class="w-5 h-5"></i>
                <span>Học kỳ</span>
            </a>
            <a href="/Admin/Subjects" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Subject") == true ? "active" : "")">
                <i data-lucide="book-open" class="w-5 h-5"></i>
                <span>Môn học</span>
            </a>
            <a href="/Admin/Classes" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Class") == true ? "active" : "")">
                <i data-lucide="graduation-cap" class="w-5 h-5"></i>
                <span>Lớp học</span>
            </a>

            <p class="text-slate-500 text-xs font-semibold uppercase tracking-wider px-4 mb-2 mt-4">Báo cáo</p>
            <a href="/Admin/Reports" class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Report") == true ? "active" : "")">
                <i data-lucide="bar-chart-2" class="w-5 h-5"></i>
                <span>Báo cáo</span>
            </a>
        </nav>

        <!-- User Info Footer -->
        <div class="p-4 border-t border-white/10">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-full bg-fpt-orange flex items-center justify-center text-white text-sm font-bold">
                    @(ViewData["UserInitial"] ?? "A")
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-white text-sm font-medium truncate">@(ViewData["FullName"] ?? "Admin")</p>
                    <p class="text-slate-400 text-xs">Quản trị viên</p>
                </div>
                <a href="/Auth/Logout" title="Đăng xuất" class="text-slate-400 hover:text-white transition-colors">
                    <i data-lucide="log-out" class="w-4 h-4"></i>
                </a>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="flex-1 flex flex-col overflow-hidden">
        <!-- Top Bar -->
        <header class="bg-white border-b border-slate-200 px-6 py-4 flex items-center justify-between shadow-sm">
            <div>
                <h1 class="text-xl font-bold text-slate-800">@(ViewData["Title"] ?? "Dashboard")</h1>
                <p class="text-slate-500 text-sm mt-0.5">Hệ thống quản lý sinh viên FPT</p>
            </div>
            <div class="flex items-center gap-4">
                <button id="themeToggle" class="px-3 py-1.5 rounded-lg border border-slate-300 text-xs font-semibold text-slate-700 hover:bg-slate-100 transition-colors">
                    Dark Mystic
                </button>
                <button id="notifBtn" class="relative text-slate-500 hover:text-fpt-navy transition-colors">
                    <i data-lucide="bell" class="w-5 h-5"></i>
                    <span id="notifBadge" class="hidden absolute -top-1 -right-1 w-4 h-4 bg-red-500 text-white text-xs rounded-full flex items-center justify-center">0</span>
                </button>
                <a href="/Auth/Logout" class="flex items-center gap-2 text-sm text-slate-600 hover:text-red-500 transition-colors">
                    <i data-lucide="log-out" class="w-4 h-4"></i>
                    <span>Đăng xuất</span>
                </a>
            </div>
        </header>

        <!-- Page Content -->
        <main class="flex-1 overflow-y-auto p-6">
            @RenderBody()
        </main>
    </div>
</div>

<!-- Toast Container -->
<div id="toastContainer" class="fixed top-4 right-4 z-50 space-y-2"></div>

<script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
<script src="~/js/signalr-connections.js"></script>
<script>
    AOS.init({ duration: 600, once: true });
    lucide.createIcons();

    (function () {
        const btn = document.getElementById('themeToggle');
        if (!btn) return;

        const syncLabel = () => {
            const mystic = document.documentElement.classList.contains('theme-mystic');
            btn.textContent = mystic ? 'Light Playful' : 'Dark Mystic';
        };

        btn.addEventListener('click', function () {
            const mystic = document.documentElement.classList.contains('theme-mystic');
            document.documentElement.classList.toggle('theme-mystic', !mystic);
            document.documentElement.classList.toggle('theme-playful', mystic);
            localStorage.setItem('admin-theme', mystic ? 'playful' : 'mystic');
            syncLabel();

            window.dispatchEvent(new CustomEvent('admin-theme-changed', {
                detail: { theme: mystic ? 'playful' : 'mystic' }
            }));
        });

        syncLabel();
    })();

    // SignalR notification connection
    (async function() {
        try {
            const userId = @(ViewData["UserId"] ?? 0);
            const conn = await signalRManager.connect('notification', '/hubs/notification');
            const groups = [`admin_${userId}`, 'admin_all'];
            await signalRManager.joinGroups(conn, groups);
            conn.onreconnected(async () => {
                await signalRManager.joinGroups(conn, groups);
            });

            conn.on('NewNotification', function(data) {
                showToast(data.title || data.message || 'Thông báo mới', 'info');
                const badge = document.getElementById('notifBadge');
                if (badge) {
                    badge.classList.remove('hidden');
                    badge.textContent = (parseInt(badge.textContent) || 0) + 1;
                }
            });

            signalRManager.bindAutoRefresh(conn, {
                events: ['EntityChanged', 'UserUpdated', 'ClassUpdated', 'SubjectUpdated', 'SemesterUpdated'],
                message: 'Du lieu he thong vua duoc cap nhat'
            });
        } catch(e) { console.warn('SignalR notification not connected', e); }
    })();
</script>
@RenderSection("Scripts", required: false)
</body>
</html>
