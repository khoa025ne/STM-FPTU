@page
@model FPT_SM.Web.Pages.Teacher.Grades.IndexModel
@{
    Layout = "_TeacherLayout";
    ViewData["Title"] = "Quản lý điểm";
    var sheet = Model.GradeSheet;
}

@if (TempData["Success"] != null)
{
    <div id="toast-success" class="fixed top-5 right-5 z-50 bg-teal-600 text-white px-5 py-3 rounded-xl shadow-lg flex items-center gap-3">
        <i data-lucide="check-circle" class="w-5 h-5"></i>
        <span>@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div id="toast-error" class="fixed top-5 right-5 z-50 bg-red-500 text-white px-5 py-3 rounded-xl shadow-lg flex items-center gap-3">
        <i data-lucide="x-circle" class="w-5 h-5"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<div class="flex gap-6" style="height: calc(100vh - 120px);">

    <!-- ===== Left Panel: Class List ===== -->
    <div class="w-72 flex-shrink-0 bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden flex flex-col" data-aos="fade-right">
        <div class="px-5 py-4 border-b border-slate-100 bg-gradient-to-r from-fpt-navy to-blue-800">
            <div class="flex items-center gap-2">
                <i data-lucide="star" class="w-5 h-5 text-white/80"></i>
                <h3 class="font-bold text-white">Danh sách lớp</h3>
            </div>
            <p class="text-white/60 text-xs mt-1">Chọn lớp để quản lý điểm</p>
        </div>

        <div class="overflow-y-auto flex-1">
            @if (Model.MyClasses.Any())
            {
                @foreach (var cls in Model.MyClasses)
                {
                    var isSelected = Model.SelectedClassId == cls.Id;
                    <a href="?classId=@cls.Id"
                       class="flex items-start gap-3 px-4 py-4 border-b border-slate-50 hover:bg-slate-50 transition-colors
                              @(isSelected ? "bg-fpt-navy/5 border-l-4 border-l-fpt-orange" : "border-l-4 border-l-transparent")">
                        <div class="w-9 h-9 rounded-xl @(isSelected ? "bg-fpt-navy" : "bg-slate-100") flex items-center justify-center flex-shrink-0 mt-0.5 transition-colors">
                            <i data-lucide="book-open" class="w-4 h-4 @(isSelected ? "text-white" : "text-slate-500")"></i>
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="font-semibold @(isSelected ? "text-fpt-navy" : "text-slate-700") text-sm truncate">@cls.Name</p>
                            <p class="text-xs text-slate-400 truncate mt-0.5">@cls.SubjectName</p>
                            <div class="flex items-center gap-2 mt-1.5">
                                <span class="text-xs px-1.5 py-0.5 rounded font-medium
                                    @(cls.StatusColor == "teal" ? "bg-teal-100 text-teal-700" :
                                      cls.StatusColor == "sky"  ? "bg-sky-100 text-sky-700" :
                                      cls.StatusColor == "red"  ? "bg-red-100 text-red-700" : "bg-slate-100 text-slate-500")">
                                    @cls.StatusName
                                </span>
                                <span class="text-xs text-slate-400">@cls.Enrolled SV</span>
                            </div>
                        </div>
                    </a>
                }
            }
            else
            {
                <div class="flex flex-col items-center justify-center py-16 text-center px-4">
                    <i data-lucide="inbox" class="w-10 h-10 text-slate-300 mb-3"></i>
                    <p class="text-slate-500 text-sm font-medium">Chưa có lớp nào</p>
                </div>
            }
        </div>
    </div>

    <!-- ===== Right Panel: Grade Sheet ===== -->
    <div class="flex-1 min-w-0 overflow-y-auto" data-aos="fade-up">

        @if (Model.SelectedClassId.HasValue && sheet != null)
        {
            <!-- Header Info -->
            <div class="bg-gradient-to-r from-fpt-navy to-blue-800 rounded-2xl px-6 py-5 mb-4">
                <div class="flex items-start justify-between flex-wrap gap-4">
                    <div>
                        <h2 class="text-white font-bold text-xl">@sheet.ClassName</h2>
                        <p class="text-white/70 text-sm mt-1">
                            <span class="bg-white/10 px-2 py-0.5 rounded">@sheet.SubjectName</span>
                            &nbsp;·&nbsp; @sheet.SemesterName
                        </p>
                        <div class="flex items-center gap-4 mt-3 text-sm">
                            <span class="text-white/80">Tổng: <strong class="text-white">@sheet.Grades.Count</strong> sinh viên</span>
                            <span class="text-white/80">Đậu: <strong class="text-teal-300">@sheet.Grades.Count(g => g.IsPassed && g.Status == 2)</strong></span>
                            <span class="text-white/80">Rớt: <strong class="text-red-300">@sheet.Grades.Count(g => !g.IsPassed && g.Status == 2)</strong></span>
                        </div>
                    </div>
                    <!-- Action Buttons -->
                    <div class="flex items-center gap-2 flex-wrap">
                        <form method="post" asp-page-handler="AnalyzeWithAI" class="inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="classId" value="@sheet.ClassId" />
                            <button type="submit"
                                    class="flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white text-sm font-medium px-4 py-2 rounded-xl transition-all border border-white/20">
                                <i data-lucide="sparkles" class="w-4 h-4 text-yellow-300"></i>
                                Phân tích AI
                            </button>
                        </form>
                        @if (sheet.Grades.Any(g => g.Status == 2))
                        {
                                <form method="post" asp-page-handler="ReopenGrades" class="inline"
                                    onsubmit="return confirmReopen(this);">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="classId" value="@sheet.ClassId" />
                                <button type="submit"
                                        class="flex items-center gap-2 bg-amber-500 hover:bg-amber-600 text-white text-sm font-bold px-4 py-2 rounded-xl transition-all shadow-sm">
                                    <i data-lucide="unlock" class="w-4 h-4"></i>
                                    Mở chấm lại
                                </button>
                            </form>
                        }
                        <button type="button" onclick="confirmPublish(@sheet.ClassId)"
                                class="flex items-center gap-2 bg-fpt-orange hover:bg-orange-600 text-white text-sm font-bold px-4 py-2 rounded-xl transition-all shadow-sm">
                            <i data-lucide="send" class="w-4 h-4"></i>
                            Publish Điểm
                        </button>
                    </div>
                </div>
            </div>

            <!-- Grade Sheet Table -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
                    <div>
                        <h3 class="font-bold text-slate-800">Bảng điểm</h3>
                        <p class="text-slate-400 text-xs mt-0.5">GPA = Giữa kỳ × 40% + Cuối kỳ × 60%</p>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="text-xs text-slate-400">Đậu: GPA ≥ 5 và Cuối kỳ ≥ 4</span>
                    </div>
                </div>

                <form method="post" asp-page-handler="SaveAllGrades" id="grades-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="classId" value="@sheet.ClassId" />

                    <div class="overflow-x-auto">
                        <table class="w-full text-sm">
                            <thead>
                                <tr class="bg-slate-50 text-left">
                                    <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase w-10">STT</th>
                                    <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Mã SV</th>
                                    <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Họ tên</th>
                                    <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase text-center w-36">Giữa kỳ (40%)</th>
                                    <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase text-center w-36">Cuối kỳ (60%)</th>
                                    <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase text-center w-28">GPA</th>
                                    <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase text-center w-28">Kết quả</th>
                                    <th class="px-4 py-3 text-xs font-semibold text-slate-500 uppercase text-center w-28">Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-50" id="grade-body">
                                @for (int i = 0; i < sheet.Grades.Count; i++)
                                {
                                    var g = sheet.Grades[i];
                                    var isPublished = g.Status == 2;
                                    <tr class="hover:bg-slate-50/70 transition-colors grade-row @(isPublished ? "opacity-90" : "")">
                                        <td class="px-4 py-3 text-slate-400">@(i + 1)</td>
                                        <td class="px-4 py-3">
                                            <span class="font-mono text-xs bg-slate-100 px-2 py-1 rounded-lg text-slate-600">
                                                @(g.StudentRollNumber ?? "—")
                                            </span>
                                        </td>
                                        <td class="px-4 py-3 font-semibold text-slate-700">@g.StudentName</td>

                                        <input type="hidden" name="GradeItems[@i].GradeId" value="@g.Id" />

                                        <!-- Midterm Score -->
                                        <td class="px-4 py-3 text-center">
                                            @if (isPublished)
                                            {
                                                <span class="text-slate-600 font-semibold">@(g.MidtermScore?.ToString("F1") ?? "—")</span>
                                                <input type="hidden" name="GradeItems[@i].MidtermScore" value="@g.MidtermScore" />
                                            }
                                            else
                                            {
                                                <input type="number" name="GradeItems[@i].MidtermScore"
                                                       value="@g.MidtermScore" min="0" max="10" step="0.1"
                                                       class="score-input w-20 text-center border border-slate-200 rounded-lg px-2 py-1.5 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-fpt-navy/20 focus:border-fpt-navy/40 transition-all"
                                                       data-row="@i" onchange="calcGPA(this)" oninput="calcGPA(this)" />
                                            }
                                        </td>

                                        <!-- Final Score -->
                                        <td class="px-4 py-3 text-center">
                                            @if (isPublished)
                                            {
                                                <span class="text-slate-600 font-semibold">@(g.FinalScore?.ToString("F1") ?? "—")</span>
                                                <input type="hidden" name="GradeItems[@i].FinalScore" value="@g.FinalScore" />
                                            }
                                            else
                                            {
                                                <input type="number" name="GradeItems[@i].FinalScore"
                                                       value="@g.FinalScore" min="0" max="10" step="0.1"
                                                       class="score-input w-20 text-center border border-slate-200 rounded-lg px-2 py-1.5 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-fpt-navy/20 focus:border-fpt-navy/40 transition-all"
                                                       data-row="@i" onchange="calcGPA(this)" oninput="calcGPA(this)" />
                                            }
                                        </td>

                                        <!-- GPA (auto-calculated) -->
                                        <td class="px-4 py-3 text-center">
                                            <span id="gpa-@i" class="text-lg font-black @(g.GPA.HasValue && g.GPA >= 5 ? "text-teal-600" : g.GPA.HasValue ? "text-red-500" : "text-slate-400")">
                                                @(g.GPA?.ToString("F2") ?? "—")
                                            </span>
                                        </td>

                                        <!-- Result -->
                                        <td class="px-4 py-3 text-center">
                                            <span id="result-@i" class="inline-flex items-center gap-1 text-xs font-bold px-2.5 py-1 rounded-full
                                                @(!g.GPA.HasValue ? "bg-slate-100 text-slate-500" :
                                                  g.IsPassed ? "bg-teal-100 text-teal-700" : "bg-red-100 text-red-600")">
                                                @(!g.GPA.HasValue ? "Chưa có điểm" : g.ResultText)
                                            </span>
                                        </td>

                                        <!-- Status -->
                                        <td class="px-4 py-3 text-center">
                                            <span class="inline-flex items-center gap-1 text-xs font-semibold px-2.5 py-1 rounded-full
                                                @(g.Status == 2 ? "bg-teal-100 text-teal-700" :
                                                  g.Status == 3 ? "bg-sky-100 text-sky-700" :
                                                  g.Status == 1 ? "bg-amber-100 text-amber-700" : "bg-slate-100 text-slate-500")">
                                                @(g.Status == 0 ? "Trống" : g.StatusName)
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Footer -->
                    <div class="px-6 py-4 border-t border-slate-100 bg-slate-50/50 flex items-center justify-between">
                        <p class="text-sm text-slate-500">
                            <strong class="text-fpt-navy">@sheet.Grades.Count(g => g.Status != 2)</strong> chưa công bố &nbsp;·&nbsp;
                            <strong class="text-teal-600">@sheet.Grades.Count(g => g.Status == 2)</strong> đã công bố
                        </p>
                        <button type="submit" onclick="return validateGrades()"
                                class="flex items-center gap-2 bg-fpt-navy hover:bg-blue-900 active:scale-95 text-white font-semibold px-6 py-2.5 rounded-xl transition-all shadow-sm">
                            <i data-lucide="save" class="w-4 h-4"></i>
                            Lưu tất cả
                        </button>
                    </div>
                </form>
            </div>

            <!-- Publish Form (hidden, triggered by button) -->
            <form method="post" asp-page-handler="PublishGrades" id="publish-form" class="hidden">
                @Html.AntiForgeryToken()
                <input type="hidden" name="classId" id="publish-class-id" value="@sheet.ClassId" />
            </form>
        }
        else if (Model.SelectedClassId.HasValue)
        {
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 flex flex-col items-center justify-center py-24 text-center">
                <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mb-4">
                    <i data-lucide="file-x" class="w-8 h-8 text-slate-400"></i>
                </div>
                <p class="text-slate-600 font-semibold">Không có dữ liệu điểm</p>
                <p class="text-slate-400 text-sm mt-1">Lớp chưa có sinh viên đăng ký</p>
            </div>
        }
        else
        {
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 flex flex-col items-center justify-center py-32 text-center">
                <div class="w-24 h-24 bg-fpt-navy/5 rounded-full flex items-center justify-center mb-6">
                    <i data-lucide="star" class="w-12 h-12 text-fpt-navy/25"></i>
                </div>
                <h3 class="text-slate-600 font-bold text-xl">Chọn lớp để quản lý điểm</h3>
                <p class="text-slate-400 text-sm mt-2 max-w-sm">Chọn một lớp học từ danh sách bên trái để xem và nhập điểm cho sinh viên</p>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    // Auto-hide toasts
    setTimeout(() => {
        document.getElementById('toast-success')?.remove();
        document.getElementById('toast-error')?.remove();
    }, 4000);

    // Validate grades before saving
    function validateGrades() {
        const inputs = document.querySelectorAll('.score-input');
        if (inputs.length === 0) {
            Swal.fire({
                icon: 'warning',
                title: 'Không có dữ liệu',
                text: 'Lớp này chưa có sinh viên đăng ký.',
                confirmButtonColor: '#FF6B35'
            });
            return false;
        }
        return true;
    }

    function confirmReopen(form) {
        Swal.fire({
            title: 'Mở chấm lại?',
            html: '<p class="text-gray-600">Điểm đã công bố sẽ chuyển sang trạng thái <strong>Đánh giá lại</strong> để có thể chỉnh sửa.</p>',
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#F59E0B',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Mở chấm lại',
            cancelButtonText: 'Hủy',
            reverseButtons: true
        }).then(result => {
            if (result.isConfirmed) {
                form.submit();
            }
        });
        return false;
    }

    // Auto-calculate GPA on score change
    function calcGPA(input) {
        const row = input.dataset.row;
        const tr = input.closest('tr');
        const inputs = tr.querySelectorAll('.score-input');
        let mid = null, fin = null;
        inputs.forEach(inp => {
            const name = inp.getAttribute('name');
            const val = parseFloat(inp.value);
            if (!isNaN(val)) {
                if (name.includes('MidtermScore')) mid = val;
                if (name.includes('FinalScore')) fin = val;
            }
        });

        const gpaEl = document.getElementById(`gpa-${row}`);
        const resultEl = document.getElementById(`result-${row}`);

        if (mid !== null && fin !== null) {
            const gpa = (mid * 0.4 + fin * 0.6).toFixed(2);
            const passed = parseFloat(gpa) >= 5 && fin >= 4;
            gpaEl.textContent = gpa;
            gpaEl.className = `text-lg font-black ${parseFloat(gpa) >= 5 ? 'text-teal-600' : 'text-red-500'}`;
            resultEl.textContent = passed ? 'ĐẠT' : 'KHÔNG ĐẠT';
            resultEl.className = `inline-flex items-center gap-1 text-xs font-bold px-2.5 py-1 rounded-full ${passed ? 'bg-teal-100 text-teal-700' : 'bg-red-100 text-red-600'}`;
        } else {
            gpaEl.textContent = '—';
            gpaEl.className = 'text-lg font-black text-slate-400';
            resultEl.textContent = 'Chưa có điểm';
            resultEl.className = 'inline-flex items-center gap-1 text-xs font-bold px-2.5 py-1 rounded-full bg-slate-100 text-slate-500';
        }
    }

    // SweetAlert2 confirm before publishing
    function confirmPublish(classId) {
        Swal.fire({
            title: 'Công bố điểm?',
            html: '<p class="text-gray-600">Sau khi công bố, điểm sẽ <strong>không thể chỉnh sửa</strong>.<br>Sinh viên sẽ nhận thông báo ngay lập tức.</p>',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#FF6B35',
            cancelButtonColor: '#6b7280',
            confirmButtonText: '✓ Công bố ngay',
            cancelButtonText: 'Hủy',
            reverseButtons: true
        }).then(result => {
            if (result.isConfirmed) {
                document.getElementById('publish-class-id').value = classId;
                document.getElementById('publish-form').submit();
            }
        });
    }

    // SignalR: join grade hub class group
    (async function() {
        try {
            const classId = @(Model.SelectedClassId ?? 0);
            if (!classId) return;
            const conn = signalRManager.get('grade');
            if (conn) {
                await conn.invoke('JoinGroup', `class_${classId}`);
                conn.on('GradeUpdated', data => {
                    showToast('Điểm đã được cập nhật!', 'info');
                });
                conn.on('GradesPublished', data => {
                    if (data.classId === classId) {
                        showToast('Điểm đã được công bố thành công!', 'success');
                    }
                });
                conn.on('AIAnalysisComplete', data => {
                    if (data.classId === classId) {
                        showToast('Phân tích AI hoàn thành!', 'success');
                    }
                });
            }
        } catch(e) { console.warn('SignalR grade error:', e); }
    })();
</script>
}
