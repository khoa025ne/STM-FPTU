@page
@model FPT_SM.Web.Pages.Teacher.Quizzes.DetailsModel
@{
    Layout = "_TeacherLayout";
    ViewData["Title"] = "Chi tiết Quiz";
}

<div class="flex items-center justify-between mb-6" data-aos="fade-down">
    <div>
        <a href="/Teacher/Quizzes?classId=@Model.ClassId" class="text-fpt-orange hover:text-orange-600 text-sm font-medium inline-flex items-center gap-1 mb-2">
            <i data-lucide="arrow-left" class="w-4 h-4"></i>
            Quay lại
        </a>
        <h1 class="text-2xl font-black text-fpt-navy">@Model.Quiz?.Title</h1>
        <p class="text-slate-400 text-sm mt-0.5">Thống kê và quản lý nộp bài của học sinh</p>
    </div>
</div>

<!-- Quiz Info -->
<div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 mb-6" data-aos="fade-up">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div>
            <p class="text-slate-500 text-xs font-semibold uppercase">Bắt đầu</p>
            <p class="text-lg font-bold text-slate-800 mt-1">@Model.Quiz?.StartTime.ToString("dd/MM HH:mm")</p>
        </div>
        <div>
            <p class="text-slate-500 text-xs font-semibold uppercase">Kết thúc</p>
            <p class="text-lg font-bold text-slate-800 mt-1">@Model.Quiz?.EndTime.ToString("dd/MM HH:mm")</p>
        </div>
        <div>
            <p class="text-slate-500 text-xs font-semibold uppercase">Thời lượng</p>
            <p class="text-lg font-bold text-slate-800 mt-1">@Model.Quiz?.DurationMinutes phút</p>
        </div>
        <div>
            <p class="text-slate-500 text-xs font-semibold uppercase">Số câu</p>
            <p class="text-lg font-bold text-slate-800 mt-1">@Model.Quiz?.QuestionCount câu</p>
        </div>
    </div>
</div>

<!-- Statistics -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6" data-aos="fade-up" data-aos-delay="50">
    <div class="bg-gradient-to-br from-fpt-navy to-blue-800 rounded-xl p-5 text-white">
        <p class="text-xs text-blue-200 mb-1">Tổng sinh viên</p>
        <p class="text-4xl font-black">@Model.TotalStudents</p>
    </div>
    <div class="bg-gradient-to-br from-teal-400 to-teal-600 rounded-xl p-5 text-white">
        <p class="text-xs text-teal-100 mb-1">Đã nộp bài</p>
        <p class="text-4xl font-black">@Model.SubmittedCount</p>
        <p class="text-xs text-teal-100 mt-2">@(Model.TotalStudents > 0 ? Math.Round((double)Model.SubmittedCount / Model.TotalStudents * 100, 1) : 0)%</p>
    </div>
    <div class="bg-gradient-to-br from-fpt-orange to-orange-600 rounded-xl p-5 text-white">
        <p class="text-xs text-orange-100 mb-1">Chưa nộp</p>
        <p class="text-4xl font-black">@Model.NotSubmittedCount</p>
        <p class="text-xs text-orange-100 mt-2">@(Model.TotalStudents > 0 ? Math.Round((double)Model.NotSubmittedCount / Model.TotalStudents * 100, 1) : 0)%</p>
    </div>
</div>

<!-- Export Button -->
@if (Model.CanExportReport)
{
    <div class="mb-6" data-aos="fade-up">
        <button id="btnExport" class="flex items-center gap-2 bg-teal-600 hover:bg-teal-700 text-white font-semibold px-4 py-2.5 rounded-xl transition-colors shadow-sm">
            <i data-lucide="download" class="w-4 h-4"></i>
            Xuất báo cáo (CSV)
        </button>
    </div>
}
else
{
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-6 flex items-center gap-3" data-aos="fade-up">
        <i data-lucide="alert-circle" class="w-5 h-5 text-amber-600 flex-shrink-0"></i>
        <div>
            <p class="text-amber-800 text-sm font-medium">Chưa hết giờ làm bài</p>
            <p class="text-amber-700 text-xs mt-0.5">@Model.ExportMessage</p>
        </div>
    </div>
}

<!-- Submissions Table -->
<div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden" data-aos="fade-up">
    <div class="px-6 py-4 border-b border-slate-100">
        <h3 class="font-bold text-slate-800">Danh sách nộp bài</h3>
        <p class="text-xs text-slate-400 mt-1">Hiển thị tất cả sinh viên trong lớp</p>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-slate-50 text-slate-500 text-xs font-semibold uppercase tracking-wider">
                <tr>
                    <th class="px-6 py-3 text-left">Mã SV</th>
                    <th class="px-6 py-3 text-left">Tên sinh viên</th>
                    <th class="px-6 py-3 text-center">Điểm</th>
                    <th class="px-6 py-3 text-center">Lần làm</th>
                    <th class="px-6 py-3 text-center">Giờ làm</th>
                    <th class="px-6 py-3 text-center">Giờ nộp</th>
                    <th class="px-6 py-3 text-center">Trạng thái</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var report in Model.SubmissionReports)
                {
                    var statusColor = report.Status == "Graded" ? "teal"
                        : report.Status == "Submitted" ? "blue"
                        : report.Status == "InProgress" ? "amber"
                        : "slate";

                    var statusText = report.Status == "Graded" ? "Đã chấm"
                        : report.Status == "Submitted" ? "Đã nộp"
                        : report.Status == "InProgress" ? "Đang làm"
                        : "Chưa làm";

                    <tr class="hover:bg-slate-50/50 transition-colors">
                        <td class="px-6 py-3 text-slate-800 font-semibold">@report.StudentCode</td>
                        <td class="px-6 py-3 text-slate-700">@report.StudentName</td>
                        <td class="px-6 py-3 text-center">
                            <span class="font-bold text-slate-800">
                                @(report.Status == "NotStarted" ? "-" : $"{report.Score}/{10}")
                            </span>
                        </td>
                        <td class="px-6 py-3 text-center text-slate-600">@(report.AttemptCount == 0 ? "-" : report.AttemptCount.ToString())</td>
                        <td class="px-6 py-3 text-center text-slate-600">
                            @(report.StartedAt != DateTime.MinValue ? report.StartedAt.ToString("HH:mm") : "-")
                        </td>
                        <td class="px-6 py-3 text-center text-slate-600">
                            @(report.SubmittedAt.HasValue ? report.SubmittedAt.Value.ToString("dd/MM HH:mm") : "-")
                        </td>
                        <td class="px-6 py-3 text-center">
                            <span class="inline-block text-xs font-semibold px-2.5 py-1 rounded-full
                                @(statusColor == "teal" ? "bg-teal-100 text-teal-700"
                                : statusColor == "blue" ? "bg-blue-100 text-blue-700"
                                : statusColor == "amber" ? "bg-amber-100 text-amber-700"
                                : "bg-slate-100 text-slate-700")">
                                @statusText
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.SubmissionReports.Any())
    {
        <div class="text-center py-12 text-slate-400 px-6">
            <i data-lucide="inbox" class="w-12 h-12 mx-auto mb-3 opacity-30"></i>
            <p class="font-medium">Chưa có dữ liệu nộp bài</p>
        </div>
    }
</div>

@section Scripts {
<script>
    document.getElementById('btnExport')?.addEventListener('click', async function() {
        try {
            const response = await fetch('@(Url.Page("Details", new { quizId = Model.QuizId, classId = Model.ClassId }))', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
            });

            if (!response.ok) {
                const error = await response.json();
                showToast(error.message || 'Xuất file thất bại', 'error');
                return;
            }

            const blob = await response.blob();
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            const now = new Date().toISOString().split('T')[0];
            a.download = `Quiz_Report_${now}.csv`;
            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(url);
            a.remove();

            showToast('Xuất file thành công', 'success');
        } catch (error) {
            console.error(error);
            showToast('Có lỗi xảy ra', 'error');
        }
    });

    function showToast(message, type = 'info') {
        const bgColor = type === 'success' ? 'bg-teal-600' : type === 'error' ? 'bg-red-500' : 'bg-blue-600';
        const toast = document.createElement('div');
        toast.className = `fixed top-5 right-5 z-50 ${bgColor} text-white px-5 py-3 rounded-xl shadow-lg flex items-center gap-2`;
        toast.innerHTML = `
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
            </svg>
            <span>${message}</span>
        `;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    }
</script>
}
