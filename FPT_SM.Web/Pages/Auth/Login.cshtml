@page
@model FPT_SM.Web.Pages.Auth.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - FPT Education</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet" />
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'fpt-navy': '#002E5D',
                        'fpt-orange': '#FF6B35'
                    }
                }
            }
        }
    </script>
    <style>
        .gradient-bg {
            background: linear-gradient(135deg, #002E5D 0%, #004080 40%, #0a5c9e 70%, #FF6B35 100%);
        }
        .card-glass {
            backdrop-filter: blur(12px);
            background: rgba(255,255,255,0.97);
        }
        .input-focus:focus {
            outline: none;
            border-color: #FF6B35;
            box-shadow: 0 0 0 3px rgba(255, 107, 53, 0.15);
        }
        .btn-login {
            background: linear-gradient(135deg, #FF6B35, #e55a27);
            transition: all 0.2s ease;
        }
        .btn-login:hover {
            background: linear-gradient(135deg, #e55a27, #cc4e1e);
            transform: translateY(-1px);
            box-shadow: 0 8px 20px rgba(255,107,53,0.4);
        }
        .btn-login:active { transform: translateY(0); }
        .floating-shape {
            animation: float 6s ease-in-out infinite;
        }
        .floating-shape-2 {
            animation: float 8s ease-in-out infinite reverse;
        }
        @@keyframes float {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(5deg); }
        }
    </style>
</head>
<body class="gradient-bg min-h-screen flex items-center justify-center p-4 relative overflow-hidden">

    <!-- Decorative shapes -->
    <div class="floating-shape absolute top-10 left-10 w-32 h-32 bg-white/5 rounded-full blur-xl"></div>
    <div class="floating-shape-2 absolute bottom-20 right-10 w-48 h-48 bg-fpt-orange/10 rounded-full blur-2xl"></div>
    <div class="floating-shape absolute top-1/2 left-1/4 w-24 h-24 bg-white/5 rounded-full blur-lg"></div>
    <div class="floating-shape-2 absolute top-20 right-1/3 w-16 h-16 bg-fpt-orange/15 rounded-full blur-md"></div>

    <div class="w-full max-w-md relative z-10" data-aos="fade-up" data-aos-duration="700">
        <!-- Logo / Branding -->
        <div class="text-center mb-8" data-aos="fade-down" data-aos-delay="100">
            <div class="inline-flex items-center justify-center w-20 h-20 bg-white rounded-2xl shadow-2xl mb-4">
                <div class="flex flex-col items-center">
                    <span class="text-fpt-orange font-black text-3xl leading-none">F</span>
                    <span class="text-fpt-navy text-xs font-bold leading-none">PT</span>
                </div>
            </div>
            <h1 class="text-white font-black text-3xl tracking-tight">
                FPT <span class="text-fpt-orange">Education</span>
            </h1>
            <p class="text-white/70 text-sm mt-1">Hệ thống Quản lý Sinh viên</p>
        </div>

        <!-- Login Card -->
        <div class="card-glass rounded-3xl shadow-2xl p-8" data-aos="zoom-in" data-aos-delay="200">
            <div class="mb-6">
                <h2 class="text-2xl font-bold text-fpt-navy">Đăng nhập</h2>
                <p class="text-slate-500 text-sm mt-1">Nhập thông tin tài khoản của bạn để tiếp tục</p>
            </div>

            <!-- Error Message -->
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="mb-5 flex items-start gap-3 bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3" data-aos="shake" role="alert">
                    <i data-lucide="alert-circle" class="w-5 h-5 flex-shrink-0 mt-0.5"></i>
                    <span class="text-sm font-medium">@Model.ErrorMessage</span>
                </div>
            }

            <form method="post">
                @Html.AntiForgeryToken()

                <!-- Email Field -->
                <div class="mb-4">
                    <label for="email" class="block text-sm font-semibold text-slate-700 mb-1.5">
                        Email
                    </label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                            <i data-lucide="mail" class="w-4 h-4 text-slate-400"></i>
                        </div>
                        <input asp-for="Input.Email"
                               id="email"
                               type="email"
                               placeholder="example@fpt.edu.vn"
                               autocomplete="email"
                               class="input-focus w-full pl-10 pr-4 py-3 border border-slate-200 rounded-xl text-slate-800 text-sm bg-slate-50 transition-all duration-200 hover:border-slate-300" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Password Field -->
                <div class="mb-4">
                    <label for="password" class="block text-sm font-semibold text-slate-700 mb-1.5">
                        Mật khẩu
                    </label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                            <i data-lucide="lock" class="w-4 h-4 text-slate-400"></i>
                        </div>
                        <input asp-for="Input.Password"
                               id="password"
                               type="password"
                               placeholder="••••••••"
                               autocomplete="current-password"
                               class="input-focus w-full pl-10 pr-12 py-3 border border-slate-200 rounded-xl text-slate-800 text-sm bg-slate-50 transition-all duration-200 hover:border-slate-300" />
                        <button type="button" id="togglePassword"
                                class="absolute inset-y-0 right-0 pr-3.5 flex items-center text-slate-400 hover:text-fpt-orange transition-colors">
                            <i data-lucide="eye" id="eyeIcon" class="w-4 h-4"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.Password" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Remember Me -->
                <div class="flex items-center justify-between mb-6">
                    <label class="flex items-center gap-2 cursor-pointer select-none">
                        <input type="checkbox" name="rememberMe" id="rememberMe"
                               class="w-4 h-4 rounded border-slate-300 text-fpt-orange focus:ring-fpt-orange focus:ring-2 cursor-pointer" />
                        <span class="text-sm text-slate-600">Ghi nhớ đăng nhập</span>
                    </label>
                    <a href="#" class="text-sm text-fpt-orange hover:text-fpt-navy font-medium transition-colors">
                        Quên mật khẩu?
                    </a>
                </div>

                <!-- Login Button -->
                <button type="submit"
                        class="btn-login w-full text-white font-bold py-3.5 px-4 rounded-xl text-base flex items-center justify-center gap-2">
                    <i data-lucide="log-in" class="w-5 h-5"></i>
                    Đăng nhập
                </button>
            </form>

            <!-- Divider -->
            <div class="mt-6 pt-6 border-t border-slate-100 text-center">
                <p class="text-slate-400 text-xs">
                    © 2024 FPT Education. Hệ thống quản lý đào tạo.
                </p>
            </div>
        </div>

        <!-- Bottom tagline -->
        <p class="text-center text-white/50 text-xs mt-6" data-aos="fade-up" data-aos-delay="400">
            Chào mừng đến với hệ thống quản lý sinh viên FPT University
        </p>
    </div>

    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
    <script>
        AOS.init({ duration: 600, once: true });
        lucide.createIcons();

        // Password show/hide toggle
        const toggleBtn = document.getElementById('togglePassword');
        const passwordInput = document.getElementById('password');
        const eyeIcon = document.getElementById('eyeIcon');

        toggleBtn.addEventListener('click', function () {
            const isPassword = passwordInput.type === 'password';
            passwordInput.type = isPassword ? 'text' : 'password';
            eyeIcon.setAttribute('data-lucide', isPassword ? 'eye-off' : 'eye');
            lucide.createIcons();
        });
    </script>
</body>
</html>
